---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Baudokumentation per WhatsApp ohne neue App. Monteure chatten wie gewohnt – NexWorker sichert Zeiten, Fotos und Wissen automatisch. 15 Min. Setup, DSGVO-konform." } = Astro.props;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

		<!-- Tailwind CSS -->
		<script src="https://cdn.tailwindcss.com"></script>

		<!-- GSAP for Animations -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

		<!-- Tailwind Configuration -->
		<script>
			tailwind.config = {
				theme: {
					extend: {
						fontFamily: {
							sans: ['Inter', 'sans-serif'],
							mono: ['JetBrains Mono', 'monospace'],
						},
						colors: {
							brand: {
								DEFAULT: '#4F46E5',
								dark: '#3730A3',
								light: '#818CF8',
								50: '#EEF2FF'
							},
							surface: {
								DEFAULT: '#0F172A',
								light: '#1E293B',
								dark: '#020617'
							},
							chat: {
								bg: '#F8FAFC',
								user: '#E0F2FE',
								bot: '#FFFFFF'
							}
						},
						boxShadow: {
							'soft': '0 4px 20px -2px rgba(15, 23, 42, 0.05)',
							'floating': '0 20px 40px -10px rgba(15, 23, 42, 0.1)',
							'inner-light': 'inset 0 2px 4px 0 rgba(255, 255, 255, 0.1)',
							'glow': '0 0 20px rgba(79, 70, 229, 0.3)',
						}
					}
				}
			}
		</script>

		<!-- Custom CSS -->
		<style>
			body {
				background-color: #F8FAFC;
				color: #334155;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			.bg-grid {
				background-size: 40px 40px;
				background-image: linear-gradient(to right, rgba(15, 23, 42, 0.03) 1px, transparent 1px),
									linear-gradient(to bottom, rgba(15, 23, 42, 0.03) 1px, transparent 1px);
				mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
				-webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
			}

			.bg-grid-dark {
				background-size: 40px 40px;
				background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
									linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
			}

			.chat-bubble-user {
				position: relative;
				border-radius: 1rem;
				border-bottom-right-radius: 0.25rem;
			}
			
			.chat-bubble-bot {
				position: relative;
				border-radius: 1rem;
				border-bottom-left-radius: 0.25rem;
			}

			.clip-diagonal {
				clip-path: polygon(0 0, 100% 0, 100% 95%, 0 100%);
			}

			.chat-scroll::-webkit-scrollbar {
				width: 4px;
			}
			.chat-scroll::-webkit-scrollbar-track {
				background: transparent;
			}
			.chat-scroll::-webkit-scrollbar-thumb {
				background: #cbd5e1;
				border-radius: 4px;
			}

			.perspective-1000 {
				perspective: 1000px;
			}
		</style>
	</head>
	<body class="selection:bg-brand selection:text-white relative">
		<!-- Navigation -->
		<nav class="fixed w-full z-50 transition-all duration-300 bg-white/80 backdrop-blur-lg border-b border-slate-200">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center h-20">
					<a href="/" class="flex-shrink-0 flex items-center gap-3">
						<img src="/logo.png" alt="NexWorker" class="w-10 h-10 rounded-xl" />
						<span class="font-bold text-xl tracking-tight text-surface">NexWorker</span>
					</a>
					
					<div class="hidden md:flex items-center space-x-8">
						<!-- Lösungen Dropdown -->
						<div class="relative group">
							<button class="text-slate-500 hover:text-surface transition-colors font-medium text-sm flex items-center gap-1">
								Lösungen
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
							</button>
							<div class="absolute left-0 mt-2 w-64 bg-white border border-slate-100 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 p-2">
								<a href="/wissenssicherung-handwerk" class="block p-3 hover:bg-slate-50 rounded-lg">
									<div class="font-bold text-slate-900">Wissenssicherung</div>
									<div class="text-xs text-slate-400">Know-how im Betrieb halten</div>
								</a>
								<a href="/beweissicherung-baustelle" class="block p-3 hover:bg-slate-50 rounded-lg">
									<div class="font-bold text-slate-900">Beweissicherung</div>
									<div class="text-xs text-slate-400">Rechtssichere Dokumentation</div>
								</a>
								<a href="/whatsapp-baudokumentation" class="block p-3 hover:bg-slate-50 rounded-lg">
									<div class="font-bold text-slate-900">WhatsApp Dokumentation</div>
									<div class="text-xs text-slate-400">Dokumentation ohne App</div>
								</a>
							</div>
						</div>
						<a href="/#preise" class="text-slate-500 hover:text-surface transition-colors font-medium text-sm">Preise</a>
						<a href="/#cta" class="bg-surface hover:bg-surface-light text-white px-5 py-2.5 rounded-lg font-medium text-sm transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">Demo starten</a>
					</div>
				</div>
			</div>
		</nav>

		<slot />

		<!-- Footer -->
		<footer class="bg-surface py-10 text-center relative overflow-hidden">
			<div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-[300px] h-[100px] bg-brand/20 blur-[50px] pointer-events-none"></div>
			<div class="max-w-7xl mx-auto px-4 relative z-10 flex flex-col items-center">
				<div class="flex items-center justify-center gap-3 mb-6">
					<img src="/logo.png" alt="NexWorker" class="w-8 h-8 rounded-lg" />
					<span class="text-slate-200 font-semibold tracking-wide">NexWorker</span>
				</div>
				<div class="flex gap-6 mb-8 mt-2">
					<a href="/datenschutz" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Datenschutz</a>
					<a href="/impressum" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Impressum</a>
				</div>
				<p class="text-slate-600 text-xs font-mono">© 2026 NexTech Fusion GmbH. All rights reserved.</p>
			</div>
		</footer>

		<!-- GSAP Init Script -->
		<script>
			window.addEventListener('load', () => {
				if (typeof gsap === 'undefined') {
					console.error("GSAP not loaded.");
					return;
				}

				// Hero Elements Reveal
				const heroElements = gsap.utils.toArray('.gs-reveal-hero');
				if(heroElements.length) {
					gsap.from(heroElements, {
						y: 40,
						opacity: 0,
						duration: 1.2,
						stagger: 0.15,
						ease: "power3.out"
					});
				}

				// General Fade Up logic
				const fadeElements = gsap.utils.toArray('.gs-fade-up');
				fadeElements.forEach(elem => {
					let delay = elem.getAttribute('data-delay') || 0;
					gsap.from(elem, {
						scrollTrigger: {
							trigger: elem,
							start: "top 85%",
						},
						y: 30,
						opacity: 0,
						duration: 0.8,
						delay: parseFloat(delay),
						ease: "power2.out"
					});
				});

				// Timeline Items
				const tlItems = document.querySelectorAll('.timeline-item');
				tlItems.forEach((item, i) => {
					gsap.from(item, {
						scrollTrigger: {
							trigger: item,
							start: "top 80%",
						},
						y: 30,
						opacity: 0,
						duration: 0.6,
						delay: i * 0.1,
						ease: "power2.out"
					});
				});

				// Parallax Floating Badge
				const floatBadge = document.querySelector(".gs-float");
				if(floatBadge) {
					gsap.to(floatBadge, {
						scrollTrigger: {
							trigger: "#hero-phone-container",
							start: "top bottom",
							end: "bottom top",
							scrub: 1.5
						},
						y: -120,
						ease: "none"
					});
				}
			});
		</script>
	</body>
</html>
