---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Messenger-basierte Dokumentation fuer Handwerk. Keine App, 15 Min. Setup, DSGVO-konform." } = Astro.props;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | NexWorker</title>
		<meta name="description" content={description} />
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-50 text-slate-700 antialiased">
		<!-- Navigation Component would go here -->
		<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
				<div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
						<a href="/" class="flex items-center gap-2">
								<div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center">
										<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
								</div>
								<span class="font-bold text-slate-900">NexWorker</span>
						</a>
						<div class="hidden md:flex gap-8 items-center text-sm font-medium text-slate-600">
								<a href="#features" class="hover:text-brand transition-colors">Funktionen</a>
								<a href="#workflow" class="hover:text-brand transition-colors">Workflow</a>
								<a href="#faq" class="hover:text-brand transition-colors">FAQ</a>
								<a href="#contact" class="bg-brand hover:bg-brand-dark text-white px-5 py-2 rounded-lg transition-all shadow-soft">Demo anfordern</a>
						</div>
				</div>
		</nav>

		<slot />

		<footer class="bg-surface-dark py-12 px-6">
				<div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-12">
						<div class="col-span-2">
								<div class="flex items-center gap-2 mb-4">
										<div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center">
												<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
										</div>
										<span class="font-bold text-white">NexWorker</span>
								</div>
								<p class="text-slate-400 max-w-sm mb-6">
										Die KI-Instanz fuer Handwerk und Field-Service. 
										Dokumentation ohne App direkt in WhatsApp, Telegram und Teams.
								</p>
						</div>
						<div>
								<h4 class="text-white font-bold mb-4">Rechtlich</h4>
								<ul class="text-slate-400 flex flex-col gap-2">
										<li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
										<li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></li>
								</ul>
						</div>
						<div>
								<h4 class="text-white font-bold mb-4">Support</h4>
								<ul class="text-slate-400 flex flex-col gap-2">
										<li><a href="#contact" class="hover:text-white transition-colors">Kontakt</a></li>
										<li><a href="#faq" class="hover:text-white transition-colors">Hilfe-Center</a></li>
								</ul>
						</div>
				</div>
				<div class="max-w-6xl mx-auto mt-12 pt-8 border-t border-slate-800 text-center">
						<p class="text-slate-500 text-sm">© {new Date().getFullYear()} NexTech Fusion GmbH. All rights reserved.</p>
				</div>
		</footer>
	</body>
</html>
