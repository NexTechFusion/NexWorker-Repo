---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Baudokumentation per WhatsApp ohne neue App. Monteure chatten wie gewohnt – NexWorker sichert Zeiten, Fotos und Wissen automatisch. 15 Min. Setup, DSGVO-konform." } = Astro.props;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

		<!-- Tailwind CSS -->
		<script src="https://cdn.tailwindcss.com"></script>

		<!-- GSAP for Animations -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

		<!-- Tailwind Configuration -->
		<script>
			tailwind.config = {
				theme: {
					extend: {
						fontFamily: {
							sans: ['Inter', 'sans-serif'],
							mono: ['JetBrains Mono', 'monospace'],
						},
						colors: {
							brand: {
								DEFAULT: '#4F46E5',
								dark: '#3730A3',
								light: '#818CF8',
								50: '#EEF2FF'
							},
							surface: {
								DEFAULT: '#0F172A',
								light: '#1E293B',
								dark: '#020617'
							},
							chat: {
								bg: '#F8FAFC',
								user: '#E0F2FE',
								bot: '#FFFFFF'
							}
						},
						boxShadow: {
							'soft': '0 4px 20px -2px rgba(15, 23, 42, 0.05)',
							'floating': '0 20px 40px -10px rgba(15, 23, 42, 0.1)',
							'inner-light': 'inset 0 2px 4px 0 rgba(255, 255, 255, 0.1)',
							'glow': '0 0 20px rgba(79, 70, 229, 0.3)',
						}
					}
				}
			}
		</script>

		<!-- Custom CSS -->
		<style>
			body {
				background-color: #F8FAFC;
				color: #334155;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			.bg-grid {
				background-size: 40px 40px;
				background-image: linear-gradient(to right, rgba(15, 23, 42, 0.03) 1px, transparent 1px),
									linear-gradient(to bottom, rgba(15, 23, 42, 0.03) 1px, transparent 1px);
				mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
				-webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
			}

			.bg-grid-dark {
				background-size: 40px 40px;
				background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
									linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
			}

			.chat-bubble-user {
				position: relative;
				border-radius: 1rem;
				border-bottom-right-radius: 0.25rem;
			}
			
			.chat-bubble-bot {
				position: relative;
				border-radius: 1rem;
				border-bottom-left-radius: 0.25rem;
			}

			.clip-diagonal {
				clip-path: polygon(0 0, 100% 0, 100% 95%, 0 100%);
			}

			.chat-scroll::-webkit-scrollbar {
				width: 4px;
			}
			.chat-scroll::-webkit-scrollbar-track {
				background: transparent;
			}
			.chat-scroll::-webkit-scrollbar-thumb {
				background: #cbd5e1;
				border-radius: 4px;
			}

			.perspective-1000 {
				perspective: 1000px;
			}
		</style>
	</head>
	<body class="selection:bg-brand selection:text-white relative">
		<slot />

		<!-- GSAP Init Script -->
		<script>
			window.addEventListener('load', () => {
				if (typeof gsap === 'undefined') {
					console.error("GSAP not loaded.");
					return;
				}

				// Hero Elements Reveal
				const heroElements = gsap.utils.toArray('.gs-reveal-hero');
				if(heroElements.length) {
					gsap.from(heroElements, {
						y: 40,
						opacity: 0,
						duration: 1.2,
						stagger: 0.15,
						ease: "power3.out"
					});
				}

				// General Fade Up logic
				const fadeElements = gsap.utils.toArray('.gs-fade-up');
				fadeElements.forEach(elem => {
					let delay = elem.getAttribute('data-delay') || 0;
					gsap.from(elem, {
						scrollTrigger: {
							trigger: elem,
							start: "top 85%",
						},
						y: 30,
						opacity: 0,
						duration: 0.8,
						delay: parseFloat(delay),
						ease: "power2.out"
					});
				});

				// Timeline Items
				const tlItems = document.querySelectorAll('.timeline-item');
				tlItems.forEach((item, i) => {
					gsap.from(item, {
						scrollTrigger: {
							trigger: item,
							start: "top 80%",
						},
						y: 30,
						opacity: 0,
						duration: 0.6,
						delay: i * 0.1,
						ease: "power2.out"
					});
				});

				// Parallax Floating Badge
				const floatBadge = document.querySelector(".gs-float");
				if(floatBadge) {
					gsap.to(floatBadge, {
						scrollTrigger: {
							trigger: "#hero-phone-container",
							start: "top bottom",
							end: "bottom top",
							scrub: 1.5
						},
						y: -120,
						ease: "none"
					});
				}
			});
		</script>
	</body>
</html>
