---
const { 
  items = [
    { time: "07:00", label: "Check-In", text: "Sind am Bauabschnitt A. Richten jetzt die Geräte ein.", log: "Pos: Bauabschnitt A" },
    { time: "11:30", label: "Material", text: "ACTION: Material Parsed #458 Kabel NYM-J 50m", log: "ID #458 Cable NYM" },
    { time: "14:15", label: "Vorfall", text: "Können Rohrleitungen nicht prüfen. Pumpe defekt.", log: "BLOCKER REGISTERED" },
    { time: "16:30", label: "Abschluss", text: "Feierabend. 8 Stunden.", log: "STATE: COMPLETED" }
  ] 
} = Astro.props;
---

<section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-6 relative z-10">
        <h2 class="text-3xl font-bold text-slate-900 mb-16 text-center tracking-tight">Echtzeit-Dokumentation im Workflow</h2>
        
        <div class="relative space-y-8">
            {/* Vertical Line */}
            <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-slate-100 -translate-x-1/2 hidden md:block"></div>

            {items.map((item, index) => (
                <div class={`flex flex-col md:flex-row items-center gap-8 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                    <div class="flex-1 w-full">
                        <div class={`bg-slate-50 p-6 rounded-2xl border border-slate-100 hover:shadow-soft transition-all group ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
                            <div class={`text-sm font-bold text-brand mb-2 uppercase tracking-widest`}>{item.time} Uhr: {item.label}</div>
                            <p class="text-slate-600 italic mb-4 font-medium italic">"{item.text}"</p>
                            <div class={`inline-flex items-center gap-2 bg-slate-200/50 px-3 py-1 rounded text-[10px] font-mono font-bold text-slate-500 uppercase tracking-tighter`}>
                                <span class="w-1.5 h-1.5 bg-brand rounded-full animate-pulse"></span>
                                {item.log}
                            </div>
                        </div>
                    </div>

                    <div class="relative z-10 shrink-0 hidden md:block">
                        <div class="w-10 h-10 bg-brand rounded-full border-4 border-white shadow-glow flex items-center justify-center text-white">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                    </div>

                    <div class="flex-1 hidden md:block"></div>
                </div>
            ))}
        </div>
    </div>
</section>
