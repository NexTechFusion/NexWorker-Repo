---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProblemSolution from '../components/ProblemSolution.astro';
import MetricBanner from '../components/MetricBanner.astro';
import StepFlow from '../components/StepFlow.astro';
import FAQ from '../components/FAQ.astro';

const title = "NexWorker – WhatsApp Dokumentation ohne App";
const description = "Baudokumentation per WhatsApp ohne neue App. Monteure chatten wie gewohnt – NexWorker sichert Zeiten, Fotos und Wissen automatisch. 15 Min. Setup, DSGVO-konform.";

const problems = [
  "Mängelansprüche nicht abwehrbar",
  "Fotos auf 5 verschiedenen Handys",
  "Keine Zeitstempel, keine Projektzuordnung",
  "Zettel gehen verloren",
  "Gerichtsunverwertbare Dokumentation"
];

const solutions = [
  "Alle Fotos automatisch archiviert",
  "Zeitstempel & GPS automatisch",
  "Projektzuordnung per Chat",
  "GoBD-konform in Deutschland gehostet",
  "Gerichtsfeste Dokumentation"
];
---

<Layout title={title} description={description}>
	<Hero 
		overline="Fuer Bauleiter, Monteure, Reinigungsfirmen und Field Service"
		title="Schluss mit Zettelwirtschaft. Dokumentation ohne App."
		description={description}
		ctaText="Demo anfordern"
		ctaLink="#contact"
	/>

	<MetricBanner />

	<ProblemSolution 
		title="Warum NexWorker?"
		problems={problems}
		solutions={solutions}
	/>

	<StepFlow />

	<section class="py-24 bg-surface-dark relative overflow-hidden group">
    <div class="absolute inset-0 bg-grid-dark opacity-10 pointer-events-none group-hover:opacity-20 transition-opacity"></div>
		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
			<h2 class="text-3xl md:text-5xl font-bold text-white mb-8 tracking-tight leading-tight">Die "Ein-Klick" Abrechnung.</h2>
			<p class="text-xl text-slate-400 mb-12 max-w-2xl mx-auto leading-relaxed italic">
				Während das Team im Feierabend ist, liegt die formatierte Baudokumentation bereits auf Ihrem Schreibtisch. Sauber kategorisiert, fehlerfrei summiert und sofort fakturierbar.
			</p>
			<div class="grid md:grid-cols-2 gap-8 text-left max-w-3xl mx-auto">
				<div class="bg-surface/50 p-8 rounded-3xl border border-slate-700/50 backdrop-blur-sm">
					<h3 class="font-bold text-white text-lg mb-4 flex items-center gap-2">
						<span class="w-2 h-2 bg-brand rounded-full"></span>
						Tagesbericht
					</h3>
					<ul class="text-slate-400 text-sm space-y-3 font-mono">
						<li class="flex justify-between border-b border-slate-800 pb-2">
							<span>Projekt:</span>
							<span class="text-white">Neubau Allee (Obj. 4)</span>
						</li>
						<li class="flex justify-between border-b border-slate-800 pb-2">
							<span>Personal:</span>
							<span class="text-white">Lars (8h), Axel (8h)</span>
						</li>
						<li class="flex justify-between border-b border-slate-800 pb-2">
							<span>Leistung:</span>
							<span class="text-white">Montage (Abschnitt A)</span>
						</li>
						<li class="flex justify-between border-b border-slate-800 pb-2">
							<span>Material:</span>
							<span class="text-white">3x VPE Klemmen (147,50 EUR)</span>
						</li>
						<li class="flex justify-between">
							<span class="text-brand">Status:</span>
							<span class="text-brand font-bold underline decoration-brand/30">EXPORT READY</span>
						</li>
					</ul>
				</div>
				<div class="flex flex-col justify-center gap-6">
					<div class="flex gap-4 items-start">
						<div class="w-10 h-10 bg-brand/10 border border-brand/20 rounded-lg flex items-center justify-center text-brand shrink-0">✓</div>
						<p class="text-slate-300 text-sm leading-relaxed">Kein Freitagnachmittag-Nachtragen mehr nötig.</p>
					</div>
					<div class="flex gap-4 items-start">
						<div class="w-10 h-10 bg-brand/10 border border-brand/20 rounded-lg flex items-center justify-center text-brand shrink-0">✓</div>
						<p class="text-slate-300 text-sm leading-relaxed">Lückenlose Objekt-Historie für Beweissicherung.</p>
					</div>
					<div class="flex gap-4 items-start">
						<div class="w-10 h-10 bg-brand/10 border border-brand/20 rounded-lg flex items-center justify-center text-brand shrink-0">✓</div>
						<p class="text-slate-300 text-sm leading-relaxed">Sofortige Liquiditätssicherung durch schnellere Abrechnung.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<FAQ />

	<section id="contact" class="py-24 bg-white text-center">
		<div class="max-w-4xl mx-auto px-6">
			<h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-8 tracking-tighter">Schluss mit Zettelwirtschaft.</h2>
			<p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed">
				Testen Sie NexWorker risikofrei – bevor weiteres Wissen, weitere Fotos und weitere Zeiten unstrukturiert auf einzelnen Handys verschwinden.
			</p>
			<a href="#demo" class="bg-brand hover:bg-brand-dark text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-glow inline-block transition-all hover:scale-105">
				Kostenlose Demo anfordern
			</a>
		</div>
	</section>
</Layout>

<style>
    .bg-grid-dark {
        background-size: 40px 40px;
        background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                          linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    }
</style>
