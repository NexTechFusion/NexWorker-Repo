    <!-- ROI Calculator Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slider = document.getElementById('roi-slider');
            const display = document.getElementById('roi-display');
            
            if (slider && display) {
                slider.addEventListener('input', (e) => {
                    const monteure = parseInt(e.target.value);
                    const stundenProTag = 0.25; // 15 min
                    const tageProMonat = 20;
                    const stundensatz = 60;
                    const jahre = 1;
                    
                    const ersparnis = monteure * stundenProTag * tageProMonat * stundensatz * 12;
                    display.textContent = ersparnis.toLocaleString('de-DE') + '€';
                });
            }
        });
    </script>

