---
import Layout from '../layouts/Layout.astro';
---
<Layout title="NexWorker | Baudokumentation per Sprachnachricht | BauPVO 2026">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 transition-all duration-300 bg-white/95 backdrop-blur-lg border-b border-slate-200" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex-shrink-0 flex items-center gap-3 cursor-pointer">
                    <img src="/logo.png" alt="NexWorker" class="w-9 h-9 rounded-xl" />
                    <span class="font-bold text-lg tracking-tight text-surface">NexWorker</span>
                </div>
                
                <div class="hidden md:flex items-center space-x-6">
                    <a href="#problem" class="text-slate-500 hover:text-surface transition-colors font-medium text-sm">Problem</a>
                    <a href="#loesung" class="text-slate-500 hover:text-surface transition-colors font-medium text-sm">Lösung</a>
                    <a href="#preise" class="text-slate-500 hover:text-surface transition-colors font-medium text-sm">Preise</a>
                    <a href="#kontakt" class="bg-brand hover:bg-brand-dark text-white px-5 py-2 rounded-lg font-medium text-sm transition-all">
                        Termin buchen
                    </a>
                </div>

                <div class="md:hidden flex items-center">
                    <button class="text-slate-600 hover:text-surface focus:outline-none">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-24 pb-16 lg:pt-32 lg:pb-24 bg-white relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-slate-50 to-white pointer-events-none"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-center">
                
                <!-- Text Content -->
                <div class="lg:col-span-7 mb-12 lg:mb-0">
                    <!-- Scarcity Badge -->
                    <div class="inline-flex items-center px-4 py-2 rounded-full bg-amber-50 text-amber-800 font-semibold text-sm mb-6 border border-amber-200 animate-pulse">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                        </svg>
                        Pilot-Phase: Nur noch 8 von 10 Plätzen frei
                    </div>
                    
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6 text-surface leading-[1.1]">
                        BauPVO 2026 & NIS2<br>
                        <span class="text-brand">compliant – ohne Extra-Aufwand.</span>
                    </h1>
                    
                    <p class="text-lg md:text-xl text-slate-600 mb-8 max-w-2xl leading-relaxed">
                        Dokumentationspflichten endlich im Griff. Keine neuen Apps. Keine Schulungen. 
                        Ihr Messenger reicht – Sprachnachricht senden, fertig.
                    </p>
                    
                    <!-- ROI Calculator Mini -->
                    <div class="bg-slate-50 rounded-2xl p-6 mb-8 border border-slate-200">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <p class="text-sm text-slate-500 mb-1">Ihre Ersparnis pro Jahr:</p>
                                <p class="text-3xl font-bold text-surface" id="roi-display">36.000€</p>
                            </div>
                            <div class="text-right">
                                <label class="text-xs text-slate-400 block mb-1">Monteure</label>
                                <input type="range" min="1" max="50" value="10" id="roi-slider" class="w-24 h-2 bg-slate-300 rounded-lg appearance-none cursor-pointer">
                            </div>
                        </div>
                        <p class="text-xs text-slate-400">* 15 Min. weniger Büroarbeit/Tag bei 60€/h Verrechnungssatz</p>
                    </div>
                    
                    <!-- CTAs -->
                    <div class="flex flex-col sm:flex-row gap-4 mb-8">
                        <a href="https://calendly.com/nextech-fusion/nexworker-demo" target="_blank" class="bg-brand hover:bg-brand-dark text-white px-8 py-4 rounded-xl font-semibold text-base transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 text-center flex items-center justify-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            Kostenlos testen – 15 Min. Setup
                        </a>
                        <a href="#loesung" class="bg-white border-2 border-slate-200 hover:border-slate-300 text-slate-700 px-8 py-4 rounded-xl font-semibold text-base transition-colors text-center">
                            So funktioniert's
                        </a>
                    </div>

                    <!-- Trust Badges -->
                    <div class="flex flex-wrap items-center gap-6 text-sm text-slate-500">
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            14 Tage kostenlos
                        </div>
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Keine Kreditkarte
                        </div>
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Monatlich kündbar
                        </div>
                    </div>
                </div>

                <!-- Social Proof + Phone Mockup -->
                <div class="lg:col-span-5">
                    <!-- Social Proof Card -->
                    <div class="bg-white rounded-2xl p-6 shadow-xl border border-slate-200 mb-6">
                        <p class="text-sm text-slate-500 mb-4 font-medium">Bereits in der Pilot-Phase:</p>
                        <div class="space-y-3">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold text-sm">EM</div>
                                <div>
                                    <p class="font-semibold text-slate-800 text-sm">Elektro Müller</p>
                                    <p class="text-xs text-slate-400">München, 12 Mitarbeiter</p>
                                </div>
                                <span class="ml-auto text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full">Aktiv</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center text-orange-600 font-bold text-sm">SW</div>
                                <div>
                                    <p class="font-semibold text-slate-800 text-sm">Sanitär Weber</p>
                                    <p class="text-xs text-slate-400">Berlin, 8 Mitarbeiter</p>
                                </div>
                                <span class="ml-auto text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full">Aktiv</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center text-purple-600 font-bold text-sm">DS</div>
                                <div>
                                    <p class="font-semibold text-slate-800 text-sm">Dachdecker Schmidt</p>
                                    <p class="text-xs text-slate-400">Hamburg, 15 Mitarbeiter</p>
                                </div>
                                <span class="ml-auto text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full">Aktiv</span>
                            </div>
                        </div>
                        <div class="mt-4 pt-4 border-t border-slate-100">
                            <p class="text-xs text-slate-400">
                                <span class="font-semibold text-amber-600">2 Pilotplätze</span> noch verfügbar für März 2026
                            </p>
                        </div>
                    </div>

                    <!-- Compliance Badges -->
                    <div class="flex flex-wrap gap-3">
                        <div class="flex items-center gap-2 bg-slate-50 px-3 py-2 rounded-lg border border-slate-200">
                            <svg class="w-4 h-4 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            <span class="text-xs font-semibold text-slate-600">DSGVO-konform</span>
                        </div>
                        <div class="flex items-center gap-2 bg-slate-50 px-3 py-2 rounded-lg border border-slate-200">
                            <svg class="w-4 h-4 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
                            <span class="text-xs font-semibold text-slate-600">Made in Germany</span>
                        </div>
                        <div class="flex items-center gap-2 bg-slate-50 px-3 py-2 rounded-lg border border-slate-200">
                            <svg class="w-4 h-4 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            <span class="text-xs font-semibold text-slate-600">Deutsche Server</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Problem Section -->
    <section id="problem" class="py-20 bg-slate-900 text-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <span class="text-brand font-bold uppercase tracking-widest text-xs mb-3 block">Das Problem</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Montags morgens im Büro...</h2>
            </div>

            <div class="grid md:grid-cols-2 gap-8 mb-12">
                <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
                    <div class="text-4xl mb-4">📋</div>
                    <h3 class="font-bold text-lg mb-2">Zettelberge vom Freitag</h3>
                    <p class="text-slate-400 text-sm">Unleserliche Handschriften, fehlende Zeitstempel, verlorene Fotos. Jedes Woche dasselbe Chaos.</p>
                </div>
                <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
                    <div class="text-4xl mb-4">⏰</div>
                    <h3 class="font-bold text-lg mb-2">4 Stunden Nacharbeit</h3>
                    <p class="text-slate-400 text-sm">Jeden Montag. Werte von Zetteln abtippen, Fotos zuordnen, Berichte schreiben. Zeit, die fehlt.</p>
                </div>
                <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
                    <div class="text-4xl mb-4">💰</div>
                    <h3 class="font-bold text-lg mb-2">Verlorene Leistungen</h3>
                    <p class="text-slate-400 text-sm">Material nicht dokumentiert? Zusatzleistungen vergessen? Das kostet Sie echtes Geld.</p>
                </div>
                <div class="bg-slate-800 rounded-2xl p-6 border border-red-900/50">
                    <div class="text-4xl mb-4">⚠️</div>
                    <h3 class="font-bold text-lg mb-2 text-red-400">BauPVO 2026 kommt</h3>
                    <p class="text-slate-400 text-sm">Seit Januar 2026 ist lückenlose Materialdokumentation Pflicht. Bußgelder bis 50.000€ möglich.</p>
                </div>
            </div>

            <div class="text-center">
                <p class="text-xl text-slate-300 mb-6">Sie wissen, dass es besser gehen muss.</p>
                <p class="text-brand font-semibold text-lg">Aber Sie haben keine Zeit für neue Software.</p>
            </div>
        </div>
    </section>

    <!-- Solution Section -->
    <section id="loesung" class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="text-brand font-bold uppercase tracking-widest text-xs mb-3 block">Die Lösung</span>
                <h2 class="text-3xl md:text-4xl font-bold text-surface mb-4">3 Schritte. Fertig.</h2>
                <p class="text-lg text-slate-500 max-w-2xl mx-auto">Keine App-Installation. Keine Schulung. Ihre Monteure nutzen einfach den Messenger, den sie schon kennen.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8 mb-16">
                <!-- Step 1 -->
                <div class="text-center">
                    <div class="w-16 h-16 bg-brand/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <span class="text-2xl font-bold text-brand">1</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Sprachnachricht senden</h3>
                    <div class="bg-slate-50 rounded-xl p-4 text-left mb-4">
                        <p class="text-sm text-slate-600 italic">"Bin auf Baustelle Müller. 7:30 Anfang. Mit Thomas und Jan."</p>
                    </div>
                    <p class="text-sm text-slate-500">Sprechen statt tippen. In 10 Sekunden erledigt.</p>
                </div>

                <!-- Step 2 -->
                <div class="text-center">
                    <div class="w-16 h-16 bg-brand/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <span class="text-2xl font-bold text-brand">2</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Foto schicken (optional)</h3>
                    <div class="bg-slate-50 rounded-xl p-4 mb-4">
                        <div class="flex items-center gap-2 text-sm text-slate-600">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            Material, Mängel, Fortschritt
                        </div>
                    </div>
                    <p class="text-sm text-slate-500">Ein Foto sagt mehr als 100 Worte. Automatisch zugeordnet.</p>
                </div>

                <!-- Step 3 -->
                <div class="text-center">
                    <div class="w-16 h-16 bg-brand/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <span class="text-2xl font-bold text-brand">3</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Bericht kommt automatisch</h3>
                    <div class="bg-slate-50 rounded-xl p-4 mb-4">
                        <div class="flex items-center gap-2 text-sm text-emerald-600 font-semibold">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Tagesbericht per E-Mail
                        </div>
                    </div>
                    <p class="text-sm text-slate-500">Jeden Abend: fertiger Bericht in Ihrem Postfach. PDF + Excel.</p>
                </div>
            </div>

            <!-- Messenger Options -->
            <div class="bg-slate-50 rounded-2xl p-8 border border-slate-200">
                <h3 class="font-bold text-lg mb-4 text-center">Welcher Messenger?</h3>
                <div class="grid md:grid-cols-3 gap-4">
                    <div class="bg-white rounded-xl p-4 border border-slate-200 text-center">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-2">
                            <svg class="w-6 h-6 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                        </div>
                        <p class="font-semibold text-slate-800">Telegram</p>
                        <p class="text-xs text-emerald-600 font-medium">✓ DSGVO-konform</p>
                        <p class="text-xs text-slate-400 mt-1">Empfohlen für Pilot</p>
                    </div>
                    <div class="bg-white rounded-xl p-4 border border-slate-200 text-center">
                        <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-2">
                            <svg class="w-6 h-6 text-purple-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm3.61 5.71c.14-.04.28-.06.42-.06.22 0 .4.06.54.18.14.12.21.28.21.48 0 .14-.02.28-.06.42l-2.64 8.76c-.04.14-.12.26-.24.36-.12.1-.26.15-.42.15-.14 0-.28-.05-.42-.15l-2.04-1.44-1.44 1.08c-.08.06-.16.09-.24.09-.08 0-.15-.03-.21-.09-.06-.06-.09-.13-.09-.21l.3-2.1 4.02-3.72c.08-.08.12-.16.12-.24 0-.06-.02-.1-.06-.12-.04-.02-.1-.01-.18.03l-5.46 3.54-1.98-.78c-.12-.04-.18-.12-.18-.24 0-.12.06-.2.18-.24l7.56-2.88z"/></svg>
                        </div>
                        <p class="font-semibold text-slate-800">Signal</p>
                        <p class="text-xs text-emerald-600 font-medium">✓ DSGVO-konform</p>
                        <p class="text-xs text-slate-400 mt-1">Alternative</p>
                    </div>
                    <div class="bg-white rounded-xl p-4 border border-slate-200 text-center opacity-75">
                        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-2">
                            <svg class="w-6 h-6 text-green-600" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        </div>
                        <p class="font-semibold text-slate-800">WhatsApp</p>
                        <p class="text-xs text-amber-600 font-medium">◐ Nur Business API</p>
                        <p class="text-xs text-slate-400 mt-1">Auf Anfrage</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Output Section -->
    <section class="py-20 bg-slate-50">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="text-brand font-bold uppercase tracking-widest text-xs mb-3 block">Das Ergebnis</span>
                <h2 class="text-3xl md:text-4xl font-bold text-surface mb-4">Was Sie bekommen</h2>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-white rounded-2xl p-6 shadow-lg border border-slate-200">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                        </div>
                        <h3 class="font-bold text-lg">Tagesbericht (PDF)</h3>
                    </div>
                    <p class="text-sm text-slate-600 mb-4">Jeden Abend automatisch in Ihrem Postfach:</p>
