---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProblemSolution from '../components/ProblemSolution.astro';
import MetricBanner from '../components/MetricBanner.astro';

const title = "Beweissicherung Baustelle";
const description = "Rechtssichere Beweissicherung auf der Baustelle ohne App. DSGVO-konform, GoBD-konform, automatisch per Messenger.";

const problems = [
  "Mängelansprüche nicht abwehrbar",
  "Fotos auf 5 verschiedenen Handys",
  "Keine Zeitstempel, keine Projektzuordnung",
  "Zettel gehen verloren",
  "Gerichtsunverwertbare Dokumentation"
];

const solutions = [
  "Alle Fotos automatisch archiviert",
  "Zeitstempel & GPS automatisch",
  "Projektzuordnung per Chat",
  "GoBD-konform in Deutschland gehostet",
  "Gerichtsfeste Dokumentation"
];
---

<Layout title={title} description={description}>
	<Hero 
		overline="Rechtssichere Dokumentation"
		title="Beweissicherung Baustelle – ohne App"
		description={description}
	/>

	<ProblemSolution 
		title="Das Problem: Beweislast im Handwerk"
		problems={problems}
		solutions={solutions}
	/>

	<MetricBanner />

	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">Rechtliche Anforderungen 2026</h2>
			
			<div class="grid gap-6">
				{[
					{
						title: "EU-Bauproduktenverordnung (BauPVO 2024/3110)",
						date: "Seit 8. Januar 2026",
						text: "Material muss lückenlos zu Projekten zugeordnet werden. NexWorker erfasst automatisch Fotos, Zeitstempel und Projektzuordnung."
					},
					{
						title: "NIS2-Umsetzungsgesetz",
						date: "Frist: 6. März 2026",
						text: "Betroffene Betriebe (>50 MA, >10 Mio. €) müssen IT-Sicherheit und Dokumentation nachweisen. NexWorker sichert Kommunikationsdaten automatisch."
					},
					{
						title: "GoBD & DSGVO",
						date: "Rechtssicher",
						text: "Alle Dokumentation wird GoBD-konform archiviert. Hosting in Deutschland. Keine Daten in US-Clouds."
					}
				].map((legal) => (
					<div class="bg-slate-50 border-l-4 border-brand p-8 rounded-r-2xl hover:bg-white hover:shadow-soft transition-all cursor-default group">
						<div class="flex justify-between items-start mb-2">
							<h3 class="font-bold text-xl text-slate-900 group-hover:text-brand transition-colors tracking-tight">{legal.title}</h3>
							<span class="text-xs font-bold uppercase tracking-widest text-brand bg-brand-50 px-2 py-1 rounded inline-block whitespace-nowrap ml-4">{legal.date}</span>
						</div>
						<p class="text-slate-600 leading-relaxed font-medium">{legal.text}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="py-20 bg-surface text-center">
		<div class="max-w-3xl mx-auto px-6">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Bereit für rechtssichere Dokumentation?</h2>
			<p class="text-xl text-slate-400 mb-10">Keine App, 15 Minuten Setup, DSGVO-konform.</p>
			<a href="/#cta" class="bg-brand hover:bg-brand-dark text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-glow inline-block">
				Jetzt Demo anfordern
			</a>
		</div>
	</section>

    <!-- FAQPage Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "Was ist Beweissicherung auf der Baustelle?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Beweissicherung auf der Baustelle bezeichnet die rechtssichere Dokumentation von Baufortschritten, Mängeln und Arbeitsleistungen mit Zeitstempel und GPS-Daten. In Deutschland ist dies besonders wichtig für Gewährleistungsfälle nach BGB § 633 und VOB/B."
                }
            },
            {
                "@type": "Question",
                "name": "Ist WhatsApp für Baudokumentation DSGVO-konform?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Ja, wenn die Datenverarbeitung in Deutschland erfolgt und ein Auftragsverarbeitungsvertrag (AVV) besteht. NexWorker speichert alle Daten auf Servern in Frankfurt und erfüllt die DSGVO-Anforderungen vollständig."
                }
            },
            {
                "@type": "Question",
                "name": "Wie lange muss Baudokumentation aufbewahrt werden?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Nach BGB § 634a beträgt die Verjährungsfrist für Mängelansprüche 5 Jahre bei Bauwerken. Die dazugehörige Dokumentation muss für diesen Zeitraum vollständig und nachvollziehbar aufbewahrt werden."
                }
            },
            {
                "@type": "Question",
                "name": "Was ändert sich durch NIS-2 im März 2026?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Die NIS-2-Richtung fordert von Unternehmen mit über 50 Mitarbeitern dokumentierte Sicherheitsmaßnahmen. Baudokumentation wird zur Compliance-Pflicht. NexWorker erfüllt diese Anforderungen automatisch durch audit-sichere Archivierung."
                }
            },
            {
                "@type": "Question",
                "name": "Kann man Fotos aus WhatsApp gerichtsfest nutzen?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Ja, wenn Metadaten wie Zeitstempel, GPS und Absender korrekt erfasst werden. NexWorker extrahiert und speichert diese automatisch, sodass die Dokumentation vor Gericht als Beweismittel taugt."
                }
            }
        ]
    })} />
</Layout>
