<script>
// FAQ Toggle with event delegation
document.querySelectorAll('.faq-toggle').forEach(button => {
    button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const icon = button.querySelector('.faq-icon');
        
        if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            icon.classList.add('rotate-180');
        } else {
            content.classList.add('hidden');
            icon.classList.remove('rotate-180');
        }
    });
});

// Chat Animation - Wait for GSAP
document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
        if (typeof gsap !== 'undefined') {
            const anim1 = document.querySelector('.chat-anim-1');
            const anim2 = document.querySelector('.chat-anim-2');
            const anim3 = document.querySelector('.chat-anim-3');
            const anim4 = document.querySelector('.chat-anim-4');
            
            if (anim1) {
                gsap.to(anim1, {
                    opacity: 1,
                    y: 0,
                    duration: 0.5,
                    delay: 0.5,
                    ease: 'power2.out'
                });
                anim1.style.transform = 'translateY(10px)';
            }
            
            if (anim2) {
                gsap.to(anim2, {
                    opacity: 1,
                    y: 0,
                    duration: 0.5,
                    delay: 1.2,
                    ease: 'power2.out'
                });
                anim2.style.transform = 'translateY(10px)';
            }
            
            if (anim3) {
                gsap.to(anim3, {
                    opacity: 1,
                    y: 0,
                    duration: 0.5,
                    delay: 2,
                    ease: 'power2.out'
                });
                anim3.style.transform = 'translateY(10px)';
            }
            
            if (anim4) {
                gsap.to(anim4, {
                    opacity: 1,
                    y: 0,
                    duration: 0.5,
                    delay: 2.7,
                    ease: 'power2.out'
                });
                anim4.style.transform = 'translateY(10px)';
            }
        }
    }, 200);
});
</script>
