<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexWorker — Der digitale Bauhelfer für das Handwerk</title>
    <meta name="description" content="NexWorker: Der smarte KI-Agent, der in Ihrem Messenger lebt. Automatische Baustellendokumentation ohne neue App.">
    <meta name="theme-color" content="#0F172A">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            dark: '#0A0A0A',
                            charcoal: '#1A1A1A',
                            gray: '#2A2A2A',
                            accent: '#FF5A1F', // Construct Orange
                            red: '#D31145',
                            light: '#F5F5F5'
                        }
                    },
                    fontFamily: {
                        'heading': ['Space Grotesk', 'sans-serif'],
                        'body': ['DM Sans', 'sans-serif'],
                        'mono': ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
    
    <style>
        /* Base */
        * { box-sizing: border-box; }
        body { 
            font-family: 'DM Sans', sans-serif; 
            background: #0A0A0A;
            color: #F5F5F5;
            overflow-x: hidden;
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #1A1A1A; }
        ::-webkit-scrollbar-thumb { background: #FF5A1F; border-radius: 4px; }
        
        /* Focus */
        *:focus-visible {
            outline: 2px solid #FF5A1F;
            outline-offset: 2px;
        }
        
        /* Typography */
        h1, h2, h3, h4 { font-family: 'Space Grotesk', sans-serif; }
        
        /* Animations */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 20px rgba(255, 90, 31, 0.3); }
            50% { box-shadow: 0 0 40px rgba(255, 90, 31, 0.6); }
        }
        @keyframes gradient-shift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @keyframes slide-up {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .animate-float { animation: float 6s ease-in-out infinite; }
        .animate-glow { animation: pulse-glow 3s ease-in-out infinite; }
        .animate-slide-up { animation: slide-up 0.8s ease-out forwards; }
        
        /* Gradient Text */
        .text-gradient {
            background: linear-gradient(135deg, #FF5A1F 0%, #FF8A65 50%, #FF5A1F 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradient-shift 3s ease infinite;
        }
        
        /* Glass */
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        .glass-dark {
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        /* Noise Texture */
        .noise-bg {
            position: relative;
        }
        .noise-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
            opacity: 0.03;
            pointer-events: none;
        }
        
        /* Grid Pattern */
        .grid-pattern {
            background-image: 
                linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
        }
        
        /* Buttons */
        .btn-cta {
            background: #FF5A1F;
            color: white;
            padding: 16px 32px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .btn-cta::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transform: translateX(-100%);
            transition: transform 0.5s;
        }
        .btn-cta:hover::before { transform: translateX(100%); }
        .btn-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(255, 90, 31, 0.3);
        }
        
        .btn-outline {
            background: transparent;
            color: white;
            padding: 16px 32px;
            border-radius: 8px;
            font-weight: 600;
            border: 2px solid rgba(255,255,255,0.2);
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            border-color: #FF5A1F;
            background: rgba(255, 90, 31, 0.1);
        }
        
        /* Messenger Icons */
        .messenger-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .messenger-icon:hover { transform: scale(1.1); }
        
        /* Reduced Motion */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body class="noise-bg">
    
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-dark">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="#" class="flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-accent rounded-lg flex items-center justify-center font-heading font-bold text-xl text-white">
                    N
                </div>
                <span class="font-heading font-bold text-xl">NexWorker</span>
            </a>
            
            <div class="hidden md:flex items-center gap-8">
                <a href="#problem" class="text-sm text-gray-400 hover:text-white transition">Problem</a>
                <a href="#loesung" class="text-sm text-gray-400 hover:text-white transition">Lösung</a>
                <a href="#kanaele" class="text-sm text-gray-400 hover:text-white transition">Kanäle</a>
                <a href="#sicherheit" class="text-sm text-gray-400 hover:text-white transition">Sicherheit</a>
                <a href="#demo" class="btn-cta text-sm">Kostenlos testen</a>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
        <!-- Background -->
        <div class="absolute inset-0 grid-pattern"></div>
        <div class="absolute top-1/4 -right-1/4 w-[800px] h-[800px] bg-brand-accent/10 rounded-full blur-[150px]"></div>
        <div class="absolute bottom-1/4 -left-1/4 w-[600px] h-[600px] bg-brand-red/10 rounded-full blur-[120px]"></div>
        
        <div class="max-w-7xl mx-auto px-6 py-20 relative z-10">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <!-- Left Content -->
                <div class="space-y-8">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-gray-300">
                        <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
                        Jetzt 7 Tage kostenlos testen
                    </div>
                    
                    <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1]">
                        Baustelle.<br>
                        <span class="text-gradient">Automatisiert.</span>
                    </h1>
                    
                    <p class="text-xl text-gray-400 leading-relaxed max-w-lg">
                        Der smarte KI-Agent, der in Ihrem Messenger lebt. 
                        Dokumentiert Zeiten, Material und Mängel — während Ihre Monteure einfach nur arbeiten.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="#demo" class="btn-cta text-center">
                            Kostenlos starten
                        </a>
                        <a href="#loesung" class="btn-outline text-center">
                            So funktioniert's
                        </a>
                    </div>
                    
                    <div class="flex items-center gap-6 pt-4">
                        <div class="flex -space-x-2">
                            <div class="w-10 h-10 rounded-full bg-gray-700 border-2 border-brand-dark flex items-center justify-center text-xs">E</div>
                            <div class="w-10 h-10 rounded-full bg-gray-600 border-2 border-brand-dark flex items-center justify-center text-xs">S</div>
                            <div class="w-10 h-10 rounded-full bg-gray-500 border-2 border-brand-dark flex items-center justify-center text-xs">T</div>
                        </div>
                        <div class="text-sm text-gray-400">
                            <span class="text-white font-semibold">200+</span> Handwerksbetriebe
                        </div>
                    </div>
                </div>
                
                <!-- Right: Chat Demo -->
                <div class="relative">
                    <div class="absolute -inset-4 bg-gradient-to-br from-brand-accent/20 to-brand-red/20 rounded-3xl blur-2xl"></div>
                    <div class="relative glass rounded-3xl overflow-hidden border border-white/10">
                        <!-- Chat Header -->
                        <div class="bg-charcoal px-6 py-4 flex items-center gap-4 border-b border-white/5">
                            <div class="w-10 h-10 rounded-full bg-brand-accent flex items-center justify-center">
                                <span class="font-bold text-white">N</span>
                            </div>
                            <div>
                                <div class="font-semibold">NexWorker</div>
                                <div class="text-xs text-gray-400">Online • automatische Antwort</div>
                            </div>
                        </div>
                        
                        <!-- Chat Messages -->
                        <div class="p-6 space-y-4 min-h-[400px]">
                            <!-- User Message -->
                            <div class="flex gap-3">
                                <div class="w-8 h-8 rounded-full bg-gray-700 flex items-center justify-center text-xs font-bold">M</div>
                                <div class="bg-gray-800 rounded-2xl rounded-tl-none p-4 max-w-[80%]">
                                    <p class="text-sm">Moin, bin mit Axel am Projekt Allee. Haben 3 Rollen NYM 3x1,5 verlegt. Waren 450m. Reicht für morgen.</p>
                                </div>
                            </div>
                            
                            <!-- AI Response -->
                            <div class="flex gap-3 flex-row-reverse">
                                <div class="w-8 h-8 rounded-full bg-brand-accent flex items-center justify-center text-xs font-bold text-white">N</div>
                                <div class="bg-brand-accent/20 rounded-2xl rounded-tr-none p-4 max-w-[85%] border border-brand-accent/30">
                                    <div class="text-xs text-brand-accent font-mono mb-2">✓ Erfasst</div>
                                    <div class="space-y-1 text-sm font-mono">
                                        <div class="flex justify-between gap-4"><span class="text-gray-400">Projekt:</span> <span class="text-white">ALLEE_4</span></div>
                                        <div class="flex justify-between gap-4"><span class="text-gray-400">Material:</span> <span class="text-white">3x NYM-J</span></div>
                                        <div class="flex justify-between gap-4"><span class="text-gray-400">Menge:</span> <span class="text-white">450m</span></div>
                                        <div class="flex justify-between gap-4"><span class="text-gray-400">Mitarbeiter:</span> <span class="text-white">AXEL + DU</span></div>
                                        <div class="pt-2 mt-2 border-t border-white/10 flex justify-between gap-4"><span class="text-gray-400">ERP:</span> <span class="text-green-400">✓ Gebucht</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Status Bar -->
                        <div class="bg-charcoal px-6 py-3 flex items-center justify-between text-xs text-gray-500 border-t border-white/5">
                            <span>Letzte Aktualisierung: vor 2 Min</span>
                            <span class="flex items-center gap-2"><span class="w-2 h-2 bg-green-500 rounded-full"></span> System aktiv</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROBLEM SECTION -->
    <section id="problem" class="py-24 bg-brand-charcoal relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                    Kennen Sie das?
                </h2>
                <p class="text-xl text-gray-400">
                    Freitag 16:30 Uhr. Alle wollen nach Hause. Aber erstmal muss dokumentiert werden.
                </p>
            </div>
            
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Problem 1 -->
                <div class="glass p-8 rounded-2xl">
                    <div class="w-14 h-14 rounded-xl bg-red-500/20 flex items-center justify-center mb-6">
                        <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    </div>
                    <h3 class="font-heading text-xl font-bold mb-3">Das Zettelchaos</h3>
                    <p class="text-gray-400">Monteure vergessen aufzuschreiben, was sie verbaut haben. Fotos landen unsortiert auf 5 verschiedenen Handys.</p>
                </div>
                
                <!-- Problem 2 -->
                <div class="glass p-8 rounded-2xl">
                    <div class="w-14 h-14 rounded-xl bg-orange-500/20 flex items-center justify-center mb-6">
                        <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <h3 class="font-heading text-xl font-bold mb-3">Stundenlange Nacharbeiten</h3>
                    <p class="text-gray-400">Ihr Büro muss stundenlang alles abtippen. Datenwandel von Hand — jede Woche wieder.</p>
                </div>
                
                <!-- Problem 3 -->
                <div class="glass p-8 rounded-2xl">
                    <div class="w-14 h-14 rounded-xl bg-yellow-500/20 flex items-center justify-center mb-6">
                        <svg class="w-7 h-7 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <h3 class="font-heading text-xl font-bold mb-3">Verpasste Rechnungen</h3>
                    <p class="text-gray-400">Weil die Dokumentation fehlt, fehlen auch die Abschlagsrechnungen. Ihr Cashflow leidet.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- LOESUNG SECTION -->
    <section id="loesung" class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 grid-pattern opacity-30"></div>
        
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center mb-16">
                <span class="inline-block px-4 py-1.5 rounded-full bg-brand-accent/20 text-brand-accent text-sm font-semibold mb-4">So funktioniert's</span>
                <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                    Nix tun. <span class="text-brand-accent">Automatisch dokumentiert.</span>
                </h2>
            </div>
            
            <!-- Steps -->
            <div class="grid md:grid-cols-3 gap-8 mb-16">
                <!-- Step 1 -->
                <div class="relative">
                    <div class="absolute -top-4 -left-4 w-12 h-12 rounded-full bg-brand-accent flex items-center justify-center font-heading font-bold text-xl">1</div>
                    <div class="glass p-8 rounded-2xl pt-12">
                        <h3 class="font-heading text-xl font-bold mb-3">Chatten</h3>
                        <p class="text-gray-400">Ihre Monteure schicken wie gewohnt Nachrichten, Fotos oder Sprachnachrichten per WhatsApp, Telegram oder Signal.</p>
                    </div>
                </div>
                
                <!-- Arrow -->
                <div class="hidden md:flex items-center justify-center">
                    <svg class="w-8 h-8 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                
                <!-- Step 2 -->
                <div class="relative">
                    <div class="absolute -top-4 -left-4 w-12 h-12 rounded-full bg-brand-accent flex items-center justify-center font-heading font-bold text-xl">2</div>
                    <div class="glass p-8 rounded-2xl pt-12">
                        <h3 class="font-heading text-xl font-bold mb-3">KI verarbeitet</h3>
                        <p class="text-gray-400">NexWorker erkennt automatisch Projekt, Material, Zeiten und Mängel. Alles wird strukturiert.</p>
                    </div>
                </div>
                
                <!-- Arrow -->
                <div class="hidden md:flex items-center justify-center">
                    <svg class="w-8 h-8 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                
                <!-- Step 3 -->
                <div class="relative">
                    <div class="absolute -top-4 -left-4 w-12 h-12 rounded-full bg-brand-accent flex items-center justify-center font-heading font-bold text-xl">3</div>
                    <div class="glass p-8 rounded-2xl pt-12">
                        <h3 class="font-heading text-xl font-bold mb-3">Fertiger Bericht</h3>
                        <p class="text-gray-400">Freitags erhalten Sie einen sauberen Wochenbericht. Oder jederzeit auf Abruf per Kommando.</p>
                    </div>
                </div>
            </div>
            
            <!-- Live Example -->
            <div class="glass rounded-3xl p-8 md:p-12">
                <div class="flex items-center gap-3 mb-8">
                    <span class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></span>
                    <span class="font-mono text-sm text-gray-400">Live-Beispiel: So antwortet NexWorker</span>
                </div>
                
                <div class="grid md:grid-cols-2 gap-8">
                    <div class="space-y-4">
                        <div class="bg-gray-800/50 rounded-xl p-4 border-l-4 border-gray-600">
                            <p class="text-sm text-gray-300">"Bin fertig. 20 Steckdosen gesetzt, Flur oben durch. 8 Stunden."</p>
                        </div>
                        <div class="text-gray-500 text-sm">← Nachricht vom Monteur</div>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="bg-brand-accent/10 rounded-xl p-4 border-l-4 border-brand-accent">
                            <div class="font-mono text-sm space-y-1">
                                <div class="flex justify-between"><span class="text-gray-400">Zeit:</span> <span class="text-white">8h</span></div>
                                <div class="flex justify-between"><span class="text-gray-400">Leistung:</span> <span class="text-white">20x Steckdosen</span></div>
                                <div class="flex justify-between"><span class="text-gray-400">Bereich:</span> <span class="text-white">Flur oben ✓</span></div>
                                <div class="flex justify-between pt-2 border-t border-white/10"><span class="text-gray-400">Status:</span> <span class="text-green-400">Lohnabrechnung bereit</span></div>
                            </div>
                        </div>
                        <div class="text-gray-500 text-sm">← Automatisch erfasst</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CHANNELS SECTION -->
    <section id="kanaele" class="py-24 bg-brand-charcoal">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <span class="inline-block px-4 py-1.5 rounded-full bg-white/10 text-gray-300 text-sm font-semibold mb-4">Unterstützte Apps</span>
                <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                    Nutzen Sie, was Sie <span class="text-brand-accent">kennen.</span>
                </h2>
                <p class="text-xl text-gray-400 max-w-2xl mx-auto">
                    NexWorker funktioniert mit den Messengern, die Ihre Monteure bereits nutzen. 
                    Keine neue App, keine Schulung.
                </p>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
                <!-- WhatsApp -->
                <div class="glass rounded-2xl p-6 text-center hover:bg-white/10 transition cursor-pointer group">
                    <div class="w-14 h-14 mx-auto mb-4 bg-[#25D366] rounded-2xl flex items-center justify-center">
                        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    </div>
                    <h4 class="font-semibold mb-1">WhatsApp</h4>
                    <p class="text-xs text-gray-500">Der Klassiker</p>
                </div>
                
                <!-- Telegram -->
                <div class="glass rounded-2xl p-6 text-center hover:bg-white/10 transition cursor-pointer group">
                    <div class="w-14 h-14 mx-auto mb-4 bg-[#0088CC] rounded-2xl flex items-center justify-center">
                        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                    </div>
                    <h4 class="font-semibold mb-1">Telegram</h4>
                    <p class="text-xs text-gray-500">Schnell & sicher</p>
                </div>
                
                <!-- Signal -->
                <div class="glass rounded-2xl p-6 text-center hover:bg-white/10 transition cursor-pointer group">
                    <div class="w-14 h-14 mx-auto mb-4 bg-[#3A76F0] rounded-2xl flex items-center justify-center">
                        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.043 3.101a11.713 11.713 0 0 0-5.532 9.604c-.038-.802-.043-1.634.217-2.325.258-.718.687-1.312 1.196-1.808.509-.495 1.154-.879 1.835-1.165.274-.114.566-.187.866-.226.3-.038.602-.047.9-.009.301.039.587.132.856.279.269.147.509.335.709.558.4.447.731.952.972 1.502.241.55.403 1.123.485 1.705.041.291.058.584.073.877.015.293.009.587-.019.88-.028.293-.084.579-.166.855a6.39 6.39 0 0 1-.365.777c-.139.247-.305.477-.496.685a6.5 6.5 0 0 1-.632.573c-.246.181-.514.332-.8.449a9.37 9.37 0 0 1-.867.31 10.565 10.565 0 0 1-.92.232c-.329.065-.662.107-1.002.117l-.528.016c-.528.006-1.064-.019-1.6-.076-.536-.057-1.072-.148-1.6-.279-.528-.131-1.053-.293-1.568-.485a10.498 10.498 0 0 1-1.508-.672c-.483-.263-.949-.559-1.395-.886a9.83 9.83 0 0 1-1.216-1.017c-.369-.369-.714-.762-1.032-1.175a9.74 9.74 0 0 1-.806-1.293c-.234-.464-.44-.946-.612-1.44a10.498 10.498 0 0 1-.379-1.517c-.067-.524-.096-1.054-.087-1.584.009-.53.054-1.056.135-1.576.08-.52.202-1.028.365-1.517.163-.489.363-.96.599-1.406.236-.446.507-.872.812-1.273.305-.401.647-.78 1.022-1.135.375-.355.776-.685 1.2-.987.424-.302.873-.577 1.344-.823.471-.246.957-.464 1.456-.652.499-.188 1.01-.345 1.531-.472.521-.127 1.051-.222 1.589-.285.538-.063 1.082-.094 1.628-.093l.543.002c.534.009 1.064.04 1.59.093.526.053 1.047.138 1.562.256.515.118 1.024.267 1.523.447.499.18.988.391 1.466.631.478.24.944.511 1.396.81.452.3.888.628 1.306.983.418.355.815.74 1.188 1.152.186.206.364.42.533.642.169.222.326.452.472.689.146.237.274.482.391.733.117.251.218.51.305.774.087.264.158.534.215.808l.016.082c.057.274.097.553.12.835l.008.094c.023.282.029.567.016.852-.013.285-.041.568-.085.85-.044.282-.104.56-.181.833-.077.273-.17.54-.279.801-.109.261-.234.514-.376.757-.142.243-.301.478-.476.703-.175.225-.365.44-.57.644-.205.204-.425.397-.66.58-.235.183-.485.354-.75.512a9.63 9.63 0 0 1-.822.429c-.284.127-.574.24-.87.337-.296.097-.598.177-.905.24-.307.063-.619.11-.935.14-.316.03-.635.044-.955.046l-.539.003z"/></svg>
                    </div>
                    <h4 class="font-semibold mb-1">Signal</h4>
                    <p class="text-xs text-gray-500">Maximal sicher</p>
                </div>
                
                <!-- Slack -->
                <div class="glass rounded-2xl p-6 text-center hover:bg-white/10 transition cursor-pointer group">
                    <div class="w-14 h-14 mx-auto mb-4 bg-[#4A154B] rounded-2xl flex items-center justify-center">
                        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>
                    </div>
                    <h4 class="font-semibold mb-1">Slack</h4>
                    <p class="text-xs text-gray-500">Teams</p>
                </div>
                
                <!-- Teams -->
                <div class="glass rounded-2xl p-6 text-center hover:bg-white/10 transition cursor-pointer group">
                    <div class="w-14 h-14 mx-auto mb-4 bg-[#6264A7] rounded-2xl flex items-center justify-center">
                        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M19.404 7.28c-.057-.217-.303-.348-.546-.292-.243.056-.412.283-.376.526.012.08.44 2.131.44 2.131.144-.197.396-.32.673-.32.609 0 1.104.486 1.104 1.1 0 .277-.096.527-.256.714l-3.251 3.74c-.16.187-.378.29-.61.29-.231 0-.449-.103-.609-.29l-2.107-2.43c-.16-.187-.248-.437-.248-.7 0-.614.495-1.1 1.1-1.1.277 0 .53.124.673.32l.407 1.94s.44-2.05.44-2.14c.036-.243-.133-.47-.376-.526-.243-.056-.489.075-.546.292l-1.136 5.42c-.056.268.075.536.303.616l5.56 1.95c.227.08.49.01.647-.17l3.196-3.664c.157-.18.176-.438.05-.636l-1.36-2.116c-.126-.198-.39-.278-.588-.18l-4.698 2.31z"/></svg>
                    </div>
                    <h4 class="font-semibold mb-1">MS Teams</h4>
                    <p class="text-xs text-gray-500">Enterprise</p>
                </div>
                
                <!-- Custom -->
                <div class="glass rounded-2xl p-6 text-center hover:bg-white/10 transition cursor-pointer group border-dashed">
                    <div class="w-14 h-14 mx-auto mb-4 bg-brand-gray rounded-2xl flex items-center justify-center">
                        <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                    </div>
                    <h4 class="font-semibold mb-1 text-gray-400">Andere?</h4>
                    <p class="text-xs text-gray-500">API verfügbar</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECURITY SECTION -->
    <section id="sicherheit" class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-brand-charcoal to-brand-dark"></div>
        
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="order-2 lg:order-1">
                    <span class="inline-block px-4 py-1.5 rounded-full bg-brand-red/20 text-brand-red text-sm font-semibold mb-4">Datenschutz</span>
                    <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
                        Ihre Daten. <br><span class="text-brand-accent">Ihre Regeln.</span>
                    </h2>
                    <p class="text-xl text-gray-400 mb-8">
                        Im deutschen Mittelstand sind Betriebsgeheimnisse heilig. 
                        Deshalb bieten wir zwei Deployments an.
                    </p>
                    
                    <div class="space-y-6">
                        <div class="glass p-6 rounded-xl border-l-4 border-brand-accent">
                            <h4 class="font-heading font-bold text-lg mb-2">🔒 Lokale Sicherheits-Box</h4>
                            <p class="text-gray-400 text-sm">OpenClaw läuft auf einem Mini-Server in Ihrem Büro. keine externen Dien Keine Cloud,ste. 100% Offline-fähig.</p>
                        </div>
                        
                        <div class="glass p-6 rounded-xl border-l-4 border-blue-500">
                            <h4 class="font-heading font-bold text-lg mb-2">☁️ Deutsche Cloud</h4>
                            <p class="text-gray-400 text-sm">Hosting in deutschen Rechenzentren (ISO 27001). Für Unternehmen, die Skalierung benötigen.</p>
                        </div>
                    </div>
                    
                    <div class="flex flex-wrap gap-4 mt-8">
                        <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5">
                            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span class="text-sm">100% DSGVO-konform</span>
                        </div>
                        <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5">
                            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span class="text-sm">ISO 27001</span>
                        </div>
                        <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5">
                            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span class="text-sm">Made in Germany</span>
                        </div>
                    </div>
                </div>
                
                <div class="order-1 lg:order-2">
                    <div class="relative">
                        <div class="absolute inset-0 bg-brand-accent/20 blur-3xl rounded-3xl"></div>
                        <div class="relative glass rounded-3xl p-8 border border-white/10">
                            <!-- Shield Visualization -->
                            <div class="flex items-center justify-center mb-8">
                                <div class="w-32 h-40 relative">
                                    <svg viewBox="0 0 24 24" class="w-full h-full text-brand-accent" fill="currentColor">
                                        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
                                    </svg>
                                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-brand-accent rounded-full flex items-center justify-center">
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                                    </div>
                                </div>
                            </div>
                            
                            <h3 class="font-heading text-xl font-bold text-center mb-4">Sicherheits-Optionen</h3>
                            
                            <div class="space-y-3">
                                <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                                    <span class="text-sm text-gray-300">Lokale Installation</span>
                                    <span class="text-sm font-semibold text-green-400">Verfügbar</span>
                                </div>
                                <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                                    <span class="text-sm text-gray-300">Deutsche Cloud</span>
                                    <span class="text-sm font-semibold text-green-400">Verfügbar</span>
                                </div>
                                <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                                    <span class="text-sm text-gray-300">API-Zugang</span>
                                    <span class="text-sm font-semibold text-green-400">Verfügbar</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA SECTION -->
    <section id="demo" class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-brand-accent/5"></div>
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-brand-accent/10 rounded-full blur-[100px]"></div>
        
        <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
            <h2 class="font-heading text-4xl md:text-6xl font-bold mb-6">
                Bereit für die Zukunft <br>des Handwerks?
            </h2>
            <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
                In 15 Minuten angeschlossen. 7 Tage kostenlos testen. 
                Keine Kreditkarte erforderlich.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="#" class="btn-cta text-lg px-12 py-5">
                    Kostenlos testen
                </a>
                <a href="#" class="btn-outline text-lg px-12 py-5">
                    Termin vereinbaren
                </a>
            </div>
            
            <p class="mt-8 text-sm text-gray-500">
                Keine Verpflichtung • Keine Kreditkarte • 24/7 Support
            </p>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-12 border-t border-white/10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-brand-accent rounded-lg flex items-center justify-center font-heading font-bold text-white text-sm">N</div>
                    <span class="font-heading font-bold">NexWorker</span>
                </div>
                
                <div class="flex gap-8 text-sm text-gray-500">
                    <a href="#" class="hover:text-white transition">Impressum</a>
                    <a href="#" class="hover:text-white transition">Datenschutz</a>
                    <a href="#" class="hover:text-white transition">AGB</a>
                </div>
                
                <div class="text-sm text-gray-600">
                    © 2026 NexWorker Engineering GmbH
                </div>
            </div>
        </div>
    </footer>

    <script>
        gsap.registerPlugin(ScrollTrigger);
        
        // Hero animation
        gsap.from('section:first-child h1', {
            y: 50,
            opacity: 0,
            duration: 1,
            delay: 0.2
        });
        
        gsap.from('section:first-child p', {
            y: 30,
            opacity: 0,
            duration: 1,
            delay: 0.4
        });
        
        // Scroll animations
        gsap.utils.toArray('.glass, .glass-dark').forEach(el => {
            gsap.from(el, {
                scrollTrigger: {
                    trigger: el,
                    start: 'top 80%'
                },
                y: 30,
                opacity: 0,
                duration: 0.8
            });
        });
    </script>
</body>
</html>