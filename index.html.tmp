 <!-- Die 3 Kill-Shots Section -->
 <section id="kill-shots" class="py-24 bg-gray-50 border-y border-gray-200">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center max-w-3xl mx-auto mb-20 gs-fade-up">
 <span class="text-brand font-bold uppercase tracking-wider text-sm mb-2 block">Warum NexWorker gewinnt</span>
 <h2 class="text-3xl md:text-5xl font-bold text-anthracite mb-6">🛡️ Die 3 Kill-Shots</h2>
 </div>

 <div class="grid lg:grid-cols-3 gap-8">
 <!-- Card 1 -->
 <div class="bg-white rounded-2xl p-8 shadow-soft border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 relative overflow-hidden group gs-fade-up">
 <div class="absolute top-0 left-0 w-full h-1.5 bg-brand transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>
 <div class="w-16 h-16 bg-brand-50 rounded-2xl flex items-center justify-center mb-6 border border-brand/20">
 <svg class="w-8 h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 312c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
 </div>
 <h3 class="text-2xl font-bold text-anthracite mb-3">1. Der "WhatsApp-Putzmann"</h3>
 <h4 class="text-lg font-bold text-brand mb-4">Keine Schulung. Keine neue App.</h4>
 <p class="text-gray-600 mb-6 leading-relaxed">
 Ihre Monteure schicken einfach Sprachnachrichten, Fotos oder Text per WhatsApp/Telegram – so wie sie es privat sowieso tun. NexWorker sortiert das Chaos im Hintergrund.
 </p>
 <div class="bg-gray-50 p-4 rounded-lg border-l-4 border-brand">
 <p class="text-sm font-medium text-anthracite"><span class="font-bold">Der Kill-Shot:</span> Keinerlei Einarbeitung nötig. Wer chatten kann, kann NexWorker nutzen.</p>
 </div>
 </div>

 <!-- Card 2 -->
 <div class="bg-white rounded-2xl p-8 shadow-soft border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 relative overflow-hidden group gs-fade-up" data-delay="0.2">
 <div class="absolute top-0 left-0 w-full h-1.5 bg-brand transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>
 <div class="w-16 h-16 bg-brand-50 rounded-2xl flex items-center justify-center mb-6 border border-brand/20">
