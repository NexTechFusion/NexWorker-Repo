 <script>
 // GSAP Animations
 gsap.registerPlugin(ScrollTrigger);

 // Hero Reveal
 gsap.utils.toArray('.gs-reveal-hero').forEach(elem => {
 gsap.from(elem, {
 scrollTrigger: {
 trigger: elem,
 start: "top 80%",
 },
 y: 60,
 opacity: 0,
 duration: 1,
 ease: "power3.out"
 });
 });

 // Fade Up
 gsap.utils.toArray('.gs-fade-up').forEach(elem => {
 gsap.from(elem, {
 scrollTrigger: {
 trigger: elem,
 start: "top 85%",
 },
 y: 40,
 opacity: 0,
 duration: 0.8,
 ease: "power2.out"
 });
 });

 // Timeline Item Stagger
 const tlItems = document.querySelectorAll('.timeline-item');
 tlItems.forEach((item, i) => {
 gsap.from(item, {
 scrollTrigger: {
 trigger: item,
 start: "top 80%",
 },
 y: 30,
 opacity: 0,
 duration: 0.8,
 delay: i * 0.1,
 ease: "power2.out"
 });
 });

 // Parallax floating badge
 gsap.to(".gs-float", {
 scrollTrigger: {
 trigger: "#hero-phone-container",
 start: "top bottom",
 end: "bottom top",
 scrub: 1
 },
 y: -100,
 ease: "none"
 });
 </script>
</body>
</html>
