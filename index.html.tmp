 <!-- Was ist NexWorker Section -->
 <section id="was-ist" class="py-24 bg-white relative">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center max-w-3xl mx-auto mb-16 gs-fade-up">
 <span class="text-brand font-bold uppercase tracking-wider text-sm mb-2 block">Die Innovation</span>
 <h2 class="text-3xl md:text-5xl font-bold text-anthracite mb-6">🤖 Was ist NexWorker?</h2>
 <p class="text-xl text-gray-600">
 NexWorker ist kein neues System, das man lernen muss. Es ist ein <strong class="text-anthracite">smarter Kontakt in Ihrem WhatsApp, Telegram oder MS Teams</strong>.
 </p>
 </div>

 <div class="grid md:grid-cols-2 gap-12 items-center">
 <!-- Checklist -->
 <div class="space-y-6 gs-fade-up">
 <div class="flex gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors border border-transparent hover:border-gray-100">
