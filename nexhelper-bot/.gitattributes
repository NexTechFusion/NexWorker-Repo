# Enforce LF line endings for all text files.
# This eliminates CRLF-in-container bugs when scripts are authored on Windows.
* text=auto eol=lf

# Shell scripts - always LF
*.sh        text eol=lf
nexhelper-* text eol=lf
*.ps1       text eol=crlf

# Config and data files - LF
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.env       text eol=lf
Dockerfile  text eol=lf

# Binary files - no conversion
*.png       binary
*.jpg       binary
*.pdf       binary
*.zip       binary
