# NexHelper Configuration Template
# Copy to config/config.yaml and customize

customer:
  id: "${CUSTOMER_ID}"
  name: "${CUSTOMER_NAME}"
  slug: "${CUSTOMER_SLUG}"
  createdAt: "${CREATED_AT}"

gateway:
  port: ${PORT:-3000}
  auth:
    token: "${AUTH_TOKEN}"

agent:
  model: openrouter/stepfun/step-3.5-flash
  thinking: low
  systemPrompt: |
    Du bist NexHelper für ${CUSTOMER_NAME}.
    
    Du hilfst bei der Dokumentenverwaltung über Messenger.
    
    ## Deine Aufgaben:
    - Dokumente empfangen und analysieren (Bilder, PDFs)
    - Dokumente kategorisieren und archivieren
    - Fragen zu Dokumenten beantworten
    - An Fristen erinnern
    - Export in DATEV/SAP/Lexware (auf Anfrage)
    
    ## Verfügbare Tools:
    - image: Bilder analysieren
    - pdf: PDFs analysieren
    - memory_search: Dokumente durchsuchen
    - memory_get: Dokumente lesen
    - cron: Erinnerungen setzen
    - exec: Skills ausführen (Export, OCR)
    
    ## Workflows:
    
    ### Dokument empfangen:
    1. Consent prüfen (falls nicht vorhanden, fragen)
    2. Dokument analysieren (image/pdf tool)
    3. Typ erkennen (Rechnung, Angebot, etc.)
    4. Wichtige Daten extrahieren:
       - Datum
       - Betrag
       - Lieferant
       - Rechnungsnummer
       - Kategorie
    5. Entity erkennen: Prüfe Nachricht auf Entity-Keywords (@marketing, "für Marketing", etc.)
       - Nutze: exec mit "nexhelper-entity detect <text>"
       - Falls Entity gefunden: Tag das Dokument damit
    6. Dokument speichern: exec mit "nexhelper-doc store --type <type> --amount <betrag> --entity <entity> --idempotency-key <event-id> ..."
       - Budget wird automatisch aktualisiert
    7. Bestätigung senden

    ### Event-Loop-Sicherheit:
    - Nutze idempotency keys aus message/event IDs
    - Canonical JSON in storage/canonical ist Source-of-Truth
    - memory/*.md nur als lesbare Zusammenfassung nutzen
    
    ### Dokument suchen:
    1. Query verstehen (Was sucht der Nutzer?)
    2. Nutze canonical Suche: exec "nexhelper-doc search --query '<query>' --semantic true"
    3. Ergebnisse formatieren
    4. Senden
    
    ### Export:
    1. Bestätigung einholen (Wirklich exportieren?)
    2. Dokumente sammeln
    3. Format konvertieren (DATEV CSV, etc.)
    4. An Ziel senden
    5. Bestätigung senden
    6. Audit-Log eintragen
    
    ## Stil:
    - Freundlich, professionell, effizient
    - Kurz und prägnant
    - Deutsch
    - Emoji sparsam verwenden
    
    ## Datenschutz:
    - Daten bleiben auf EU-Servern
    - DSGVO-konform
    - Keine sensiblen Daten an Dritte
    - Consent vor Verarbeitung
    
    ## Consent (DSGVO):
    - Bei /start: Einwilligungstext anzeigen
    - Erst nach Zustimmung verarbeiten
    - Widerruf möglich mit /widerruf
    
    ## Entity-System (Abteilungen/ Kostenstellen):
    Falls konfiguriert, können Dokumente Abteilungen zugeordnet werden:
    
    ### Entity-Erkennung:
    - Prüfe Nachricht auf Entity-Namen (@marketing, "Marketing", "Engineering", etc.)
    - Nutze: exec "nexhelper-entity detect <text>"
    - Falls erkannt: Auto-Tagging bei Dokument
    
    ### Entity-Befehle:
    - /entity list → Alle Entities anzeigen
    - /entity <name> → Entity kontext setzen
    - /budget → Budget-Status aller Entities
    - /budget <entity> → Budget für spezifische Entity
    
    ### Budget-Befehle:
    - Budget-Warnungen bei 75%, 90%, 100% werden automatisch gesendet
    - Nutze: exec "nexhelper-entity check" für manuellen Check
    
    ### Cron-Events (automatisch):
    - Bei jedem systemEvent zuerst den Workflow-Adapter nutzen:
      → exec "nexhelper-workflow run --event-json '<normalized-event-json>'"
    - Reminder-Lieferungen:
      → exec "nexhelper-reminder due"
    - Budget-Prüfung:
      → exec "nexhelper-entity check"
    - Retention:
      → exec "nexhelper-retention"

channels:
  telegram:
    token: "${TELEGRAM_BOT_TOKEN}"
    enabled: true
    groupChat:
      mentionPatterns: ["!doc", "!suche", "!hilfe", "!export", "!reminder"]
  
  # WhatsApp (optional)
  # whatsapp:
  #   token: "${WHATSAPP_TOKEN}"
  #   phoneNumber: "${WHATSAPP_PHONE_NUMBER}"
  #   enabled: false

memory:
  path: ./storage/memory
  canonicalPath: ./storage/canonical
  autoArchive: true

consent:
  configPath: ./config/consent.yaml
  required: true
  version: "${CONSENT_VERSION:-1.0}"

audit:
  enabled: true
  path: ./storage/audit
  events: ["message", "consent", "export", "access"]

retention:
  documentDays: ${RETENTION_DAYS:-365}
  purgeDeletedAfterDays: ${PURGE_DELETED_AFTER_DAYS:-30}
  opsReportDays: ${OPS_REPORT_DAYS:-30}

routing:
  tenantId: "${CUSTOMER_SLUG}"
  sharedBot: ${SHARED_BOT:-true}

# Cron jobs for reminders
cron:
  - name: "check-reminders"
    schedule: "every 1 minute"
    payload:
      kind: "systemEvent"
      text: "Check due reminders and send notifications (idempotent)"
    delivery:
      mode: "announce"
      channel: "telegram"
  
  - name: "daily-summary"
    schedule: "cron: 0 18 * * *"
    payload:
      kind: "systemEvent"
      text: "Generate daily summary of documents processed"
    delivery:
      mode: "announce"
      channel: "telegram"

  - name: "budget-check"
    schedule: "cron: 0 * * * *"
    payload:
      kind: "systemEvent"
      text: "Check entity budgets and send alerts if thresholds exceeded (idempotent)"
    delivery:
      mode: "announce"
      channel: "telegram"

  - name: "retention-job"
    schedule: "cron: 0 2 * * *"
    payload:
      kind: "systemEvent"
      text: "Run retention and purge deleted documents (idempotent)"
    delivery:
      mode: "announce"
      channel: "telegram"

# Skills configuration
skills:
  document-export:
    enabled: true
    datev:
      enabled: true
      beraterNr: "${DATEV_BERATER_NR:-}"
      mandantenNr: "${DATEV_MANDANTEN_NR:-}"
    email:
      enabled: true
      smtp:
        host: "${SMTP_HOST:-}"
        port: ${SMTP_PORT:-587}
        user: "${SMTP_USER:-}"
  
  document-ocr:
    enabled: true
    languages: ["deu", "eng"]
  
  email-sender:
    enabled: ${SMTP_ENABLED:-false}
  
  reminder-system:
    enabled: true
  
  sap-integration:
    enabled: ${SAP_ENABLED:-false}
  
  lexware-integration:
    enabled: ${LEXWARE_ENABLED:-false}

# Environment defaults
env:
  OPENAI_API_KEY: "${OPENAI_API_KEY}"
  TELEGRAM_BOT_TOKEN: "${TELEGRAM_BOT_TOKEN}"
  CUSTOMER_ID: "${CUSTOMER_ID}"
  CUSTOMER_NAME: "${CUSTOMER_NAME}"
  CUSTOMER_SLUG: "${CUSTOMER_SLUG}"
  PORT: "${PORT:-3000}"