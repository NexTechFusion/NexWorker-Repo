#!/bin/bash

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")" 2>/dev/null || dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/nexhelper-core.sh"
# nexhelper-core.sh sets -euo pipefail; override to keep workflow resilient
set +e

DOC_SCRIPT="$SCRIPT_DIR/../document-handler/nexhelper-doc"
CLASSIFIER_SCRIPT="$SCRIPT_DIR/../classifier/nexhelper-classify"
NOTIFY_SCRIPT="$SCRIPT_DIR/nexhelper-notify"
HEALTH_SCRIPT="$SCRIPT_DIR/nexhelper-healthcheck"

normalize_event() {
  local input="$1"
  echo "$input" | jq -c '
    {
      id: (.id // .messageId // .eventId // ""),
      kind: (.kind // (if .systemEvent then "systemEvent" else "message" end)),
      channel: (.channel // "telegram"),
      senderId: (.senderId // .from // ""),
      senderUsername: (.senderUsername // .username // ""),
      senderName: (.senderName // .firstName // .displayName // ""),
      text: (.text // .message // ""),
      timestamp: (.timestamp // now | tostring),
      payload: (.payload // {})
    }'
}

_send_msg() {
  local to="$1"
  local msg="$2"
  if [ -x "$NOTIFY_SCRIPT" ]; then
    "$NOTIFY_SCRIPT" send --audience single --to "$to" --message "$msg" 2>/dev/null || true
  fi
}

_register_and_check_welcome() {
  local event_json="$1"
  local sender_id
  sender_id="$(echo "$event_json" | jq -r '.senderId // empty')"
  [ -n "$sender_id" ] || return 0

  local username display_name channel
  username="$(echo "$event_json" | jq -r '.senderUsername // empty')"
  display_name="$(echo "$event_json" | jq -r '.senderName // empty')"
  channel="$(echo "$event_json" | jq -r '.channel // "telegram"')"

  local is_new
  is_new="$(nx_user_seen "$sender_id" "$username" "$display_name" 2>/dev/null || echo 'false')"

  if [ "$is_new" = "true" ]; then
    nx_log_event "user.first_contact" "$(nx_op_id welcome)" "success" \
      "$(jq -c -n --arg u "$sender_id" --arg name "$username" '{userId:$u,username:$name}')" 2>/dev/null || true
  fi
}

route_message() {
  local event_json="$1"
  local text sender_id
  text="$(echo "$event_json" | jq -r '.text')"
  sender_id="$(echo "$event_json" | jq -r '.senderId')"

  # /start — return structured data; agent formats user reply in user's language
  if [[ "$text" =~ ^/start ]] || [[ "$text" =~ ^[Ss]tart$ ]]; then
    local role
    role="$(nx_role_get "$sender_id" 2>/dev/null || echo 'member')"
    jq -c -n \
      --arg status "start" \
      --arg userId "$sender_id" \
      --arg role "$role" \
      '{status:$status,userId:$userId,role:$role}'
    return
  fi

  # /whois @username — admin user-ID lookup
  if [[ "$text" =~ ^/whois[[:space:]] ]] || [[ "$text" =~ ^whois[[:space:]] ]]; then
    local query="${text#*whois }"
    local found
    found="$(nx_user_find_by_username "$query" 2>/dev/null || echo '')"
    if [ -z "$found" ] || [ "$found" = "{}" ]; then
      jq -c -n \
        --arg status "not_found" \
        --arg query "$query" \
        '{status:$status,query:$query}'
    else
      echo "$found" | jq -c '{status:"found",user:.}'
    fi
    return
  fi

  local classification
  classification="$("$CLASSIFIER_SCRIPT" intent --text "$text" 2>/dev/null || echo '{"intent":"noop"}')"
  local intent
  intent="$(echo "$classification" | jq -r '.intent')"

  case "$intent" in
    document_search)
      "$DOC_SCRIPT" search --query "$text" --semantic true
      ;;
    document_retrieve)
      local doc_id
      doc_id="$(echo "$classification" | jq -r '.documentId // empty')"
      if [ -n "$doc_id" ]; then
        "$DOC_SCRIPT" retrieve "$doc_id"
      else
        "$DOC_SCRIPT" search --query "$text" --semantic true
      fi
      ;;
    status)
      "$DOC_SCRIPT" stats
      ;;
    admin_promote)
      if nx_is_admin "$sender_id" 2>/dev/null; then
        local target
        target="$(echo "$classification" | jq -r '.targetUser // empty')"
        if [[ "$target" == @* ]]; then
          local resolved
          resolved="$(nx_user_find_by_username "$target" 2>/dev/null | jq -r '.userId // empty' 2>/dev/null || true)"
          [ -n "$resolved" ] && target="$resolved"
        fi
        if [ -n "$target" ]; then
          nx_policy_add_admin "$target" "$sender_id" 2>/dev/null || echo '{}'
        else
          jq -c -n --arg status "error" --arg reason "missing_target" \
            '{status:$status,reason:$reason}'
        fi
      else
        nx_require_admin "$sender_id" "admin_promote" 2>/dev/null || echo '{}'
      fi
      ;;
    admin_demote)
      if nx_is_admin "$sender_id" 2>/dev/null; then
        local target
        target="$(echo "$classification" | jq -r '.targetUser // empty')"
        if [[ "$target" == @* ]]; then
          local resolved
          resolved="$(nx_user_find_by_username "$target" 2>/dev/null | jq -r '.userId // empty' 2>/dev/null || true)"
          [ -n "$resolved" ] && target="$resolved"
        fi
        if [ -n "$target" ]; then
          nx_policy_remove_admin "$target" "$sender_id" 2>/dev/null || echo '{}'
        else
          jq -c -n --arg status "error" --arg reason "missing_target" \
            '{status:$status,reason:$reason}'
        fi
      else
        nx_require_admin "$sender_id" "admin_demote" 2>/dev/null || echo '{}'
      fi
      ;;
    *)
      # Return 'unclear' with guidance for natural response
      jq -c -n \
        --arg status "unclear" \
        --arg intent "$intent" \
        --arg text "$text" \
        --arg suggestion "ask_user_needs" \
        '{status:$status,intent:$intent,text:$text,suggestion:$suggestion,response_hint:"Frag den Nutzer natürlich, was er braucht. NIEMALS Template verwenden."}'
      ;;
  esac
}

# Resolve a structured event type from a system event text.
# Structured tokens (nexhelper:event:<type>) take priority over legacy substring matching,
# which is kept as a fallback for backward compatibility.
_resolve_event_type() {
  local text="$1"
  # Structured token (preferred): nexhelper:event:<type>
  if [[ "$text" =~ nexhelper:event:([a-z_-]+) ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi
  # Legacy substring fallback so old cron messages still work
  if [[ "$text" == *"reminder"* ]]; then echo "reminder-audit"; return; fi
  if [[ "$text" == *"budget"* ]];   then echo "budget-check";   return; fi
  if [[ "$text" == *"retention"* ]]; then echo "retention";     return; fi
  if [[ "$text" == *"health"* ]] || [[ "$text" == *"monitor"* ]] || [[ "$text" == *"degraded"* ]]; then
    echo "health-check"
    return
  fi
  if [[ "$text" == *"daily"* ]] || [[ "$text" == *"summary"* ]]; then
    echo "daily-summary"
    return
  fi
  echo "unknown"
}

route_system_event() {
  local event_json="$1"
  local text
  text="$(echo "$event_json" | jq -r '.text')"
  local event_type
  event_type="$(_resolve_event_type "$text")"

  case "$event_type" in
    reminder-audit|reminder-check)
      local sync_result="{}"
      if [ -x "$SCRIPT_DIR/../reminder-system/nexhelper-reminder-sync" ]; then
        sync_result="$("$SCRIPT_DIR/../reminder-system/nexhelper-reminder-sync" 2>/dev/null || echo '{}')"
      fi
      local audit_result="{}"
      if [ -x "$SCRIPT_DIR/../reminder-system/nexhelper-reminder-auditor" ]; then
        audit_result="$("$SCRIPT_DIR/../reminder-system/nexhelper-reminder-auditor" 2>/dev/null || echo '{}')"
      fi
      local due
      due="$("$SCRIPT_DIR/../reminder-system/nexhelper-reminder" due 2>/dev/null || echo '[]')"
      jq -c -n \
        --arg status "processed" --arg handler "reminder_due" --arg event_type "$event_type" \
        --argjson due "$due" --argjson sync "$sync_result" --argjson audit "$audit_result" \
        '{status:$status,handler:$handler,eventType:$event_type,due:$due,sync:$sync,audit:$audit}'
      ;;

    budget-check)
      local alerts
      alerts="$("$SCRIPT_DIR/../entity-system/nexhelper-entity" check 2>/dev/null || echo '[]')"
      jq -c -n --arg status "processed" --arg handler "budget_check" --arg event_type "$event_type" \
        --argjson alerts "$alerts" \
        '{status:$status,handler:$handler,eventType:$event_type,alerts:$alerts}'
      ;;

    retention)
      local retention
      retention="$("$SCRIPT_DIR/nexhelper-retention" 2>/dev/null || echo '{}')"
      jq -c -n --arg status "processed" --arg handler "retention" --arg event_type "$event_type" \
        --argjson retention "$retention" \
        '{status:$status,handler:$handler,eventType:$event_type,retention:$retention}'
      ;;

    health-check)
      local health="{}"
      if [ -x "$HEALTH_SCRIPT" ]; then
        health="$("$HEALTH_SCRIPT" 2>/dev/null || echo '{}')"
      fi
      if ! echo "$health" | jq -e . >/dev/null 2>&1; then health="{}"; fi
      local health_status
      health_status="$(echo "$health" | jq -r '.status // "unknown"')"
      if [ "$health_status" != "ok" ] && [ -x "$NOTIFY_SCRIPT" ]; then
        local degraded_checks
        degraded_checks="$(echo "$health" | jq -r '[.checks[]? | select(.status != "ok") | .name] | join(", ")' 2>/dev/null || echo 'unknown')"
        "$NOTIFY_SCRIPT" send --audience broadcast \
          --message "⚠️ NexHelper health alert: $health_status | Issues: $degraded_checks" \
          2>/dev/null || true
      fi
      jq -c -n \
        --arg status "processed" --arg handler "health_monitor" --arg event_type "$event_type" \
        --argjson health "$health" \
        '{status:$status,handler:$handler,eventType:$event_type,healthStatus:($health.status // "unknown"),health:$health}'
      ;;

    daily-summary)
      local stats="{}"
      stats="$("$DOC_SCRIPT" stats 2>/dev/null || echo '{}')"
      if ! echo "$stats" | jq -e . >/dev/null 2>&1; then stats="{}"; fi
      local health="{}"
      if [ -x "$HEALTH_SCRIPT" ]; then
        health="$("$HEALTH_SCRIPT" 2>/dev/null || echo '{}')"
      fi
      if ! echo "$health" | jq -e . >/dev/null 2>&1; then health="{}"; fi
      local health_status doc_count total_amount health_icon
      health_status="$(echo "$health" | jq -r '.status // "ok"')"
      doc_count="$(echo "$stats" | jq -r '.documents // 0')"
      total_amount="$(echo "$stats" | jq -r '.totalAmount // 0')"
      health_icon="$([ "$health_status" = "ok" ] && echo "✅" || echo "⚠️")"
      if [ -x "$NOTIFY_SCRIPT" ]; then
        "$NOTIFY_SCRIPT" send --audience broadcast \
          --message "${health_icon} Daily report: ${doc_count} doc(s), €${total_amount} total | System: ${health_status}" \
          2>/dev/null || true
      fi
      jq -c -n \
        --arg status "processed" --arg handler "daily_summary" --arg event_type "$event_type" \
        --argjson stats "$stats" --argjson health "$health" \
        '{status:$status,handler:$handler,eventType:$event_type,stats:$stats,healthStatus:($health.status // "ok")}'
      ;;

    *)
      jq -c -n --arg status "ignored" --arg text "$text" --arg event_type "$event_type" \
        '{status:$status,text:$text,eventType:$event_type}'
      ;;
  esac
}

run_event() {
  local raw_event="$1"
  local start_ms
  start_ms="$(date +%s%3N 2>/dev/null || echo 0)"
  nx_init_dirs
  local event_json
  event_json="$(normalize_event "$raw_event")"
  local event_id
  event_id="$(echo "$event_json" | jq -r '.id')"
  local key="event_${event_id}"
  if [ -n "$event_id" ] && nx_idempotency_has "$key"; then
    nx_idempotency_get "$key"
    return
  fi
  local op_id
  op_id="$(nx_op_id flow)"
  nx_log_event "workflow.received" "$op_id" "started" "$event_json" 2>/dev/null || true
  local kind
  kind="$(echo "$event_json" | jq -r '.kind')"
  
  # Metric: event received
  nx_metric_count "workflow.events.received" "kind=$kind" 2>/dev/null || true
  
  local result
  if [ "$kind" = "systemEvent" ]; then
    result="$(route_system_event "$event_json" 2>/dev/null || echo '{"status":"error","handler":"unknown"}')"
  else
    _register_and_check_welcome "$event_json" 2>/dev/null || true
    result="$(route_message "$event_json" 2>/dev/null || echo '{"status":"error"}')"
  fi
  if ! echo "$result" | jq -e . >/dev/null 2>&1; then
    result='{"status":"error","message":"internal_error"}'
  fi
  
  # Metric: processing duration
  local end_ms duration_ms
  end_ms="$(date +%s%3N 2>/dev/null || echo 0)"
  duration_ms=$((end_ms - start_ms))
  nx_metric_histogram "workflow.events.duration_ms" "$duration_ms" "kind=$kind,status=$(echo "$result" | jq -r '.status // "unknown"')" 2>/dev/null || true
  
  # Metric: by status
  nx_metric_count "workflow.events.by_status" "status=$(echo "$result" | jq -r '.status // "unknown"')" 2>/dev/null || true
  
  local output
  output="$(jq -c -n \
    --arg opId "$op_id" \
    --argjson event "$event_json" \
    --argjson result "$result" \
    '{opId:$opId,event:$event,result:$result}')"
  if [ -n "$event_id" ]; then
    nx_idempotency_put "$key" "$output" 2>/dev/null || true
  fi
  nx_log_event "workflow.completed" "$op_id" "success" "$result" 2>/dev/null || true
  echo "$output"
}

case "${1:-}" in
  run)
    shift
    if [ "${1:-}" = "--event-json" ]; then
      shift
      event_json_arg="${1:-}"
      [ -z "$event_json_arg" ] && event_json_arg="{}"
      run_event "$event_json_arg"
    else
      echo "Usage: nexhelper-workflow run --event-json '<json>'" >&2
      exit 1
    fi
    ;;
  *)
    echo "Usage: nexhelper-workflow run --event-json '<json>'" >&2
    exit 1
    ;;
esac
