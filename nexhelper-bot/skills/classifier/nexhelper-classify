#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")" 2>/dev/null || dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../common/nexhelper-core.sh"

MODEL="${CLASSIFIER_MODEL:-${AI_MODEL:-gemini-2.0-flash}}"
API_BASE="${AI_BASE_URL:-${OPENROUTER_BASE_URL:-${OPENAI_BASE_URL:-https://generativelanguage.googleapis.com/v1beta/openai}}}"
API_KEY="${AI_API_KEY:-${GEMINI_API_KEY:-${OPENROUTER_API_KEY:-${OPENAI_API_KEY:-}}}}"

usage() {
  echo "Usage:"
  echo "  nexhelper-classify intent --text <message>"
  echo "  nexhelper-classify entity --text <message> --entities-json <json-array>"
  echo "  nexhelper-classify rerank --query <query> --candidates-json <json-array>"
}

extract_content_json() {
  local response="$1"
  local has_error
  has_error="$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null || true)"
  if [ -n "$has_error" ]; then
    echo "{}"
    return
  fi
  local content_type
  content_type="$(echo "$response" | jq -r '(.choices[0].message.content | type) // "null"' 2>/dev/null || echo "null")"
  local content
  case "$content_type" in
    string)
      content="$(echo "$response" | jq -r '.choices[0].message.content // empty')"
      ;;
    array)
      content="$(echo "$response" | jq -r '[.choices[0].message.content[] | (.text // .content // "")] | join("\n")' 2>/dev/null || echo "")"
      ;;
    object)
      content="$(echo "$response" | jq -r '.choices[0].message.content.text // (.choices[0].message.content | tostring)' 2>/dev/null || echo "")"
      ;;
    *)
      content=""
      ;;
  esac
  if [ -z "$content" ]; then
    echo "{}"
    return
  fi
  if echo "$content" | jq -c . >/dev/null 2>&1; then
    echo "$content" | jq -c .
    return
  fi
  local cleaned
  cleaned="$(printf "%s" "$content" | sed '/^```/d')"
  if echo "$cleaned" | jq -c . >/dev/null 2>&1; then
    echo "$cleaned" | jq -c .
    return
  fi
  echo "{}"
}

call_model() {
  local prompt="$1"
  if [ -z "$API_KEY" ]; then
    echo ""
    return
  fi
  local models="${CLASSIFIER_MODELS:-$MODEL,gemini-2.0-flash,gemini-1.5-flash}"
  local selected
  IFS=',' read -ra MODEL_LIST <<< "$models"
  for selected in "${MODEL_LIST[@]}"; do
    selected="$(echo "$selected" | xargs)"
    [ -n "$selected" ] || continue
    local resp
    resp="$(curl -sS "$API_BASE/chat/completions" \
      -H "Authorization: Bearer $API_KEY" \
      -H "Content-Type: application/json" \
      -d "$(jq -c -n \
        --arg model "$selected" \
        --arg prompt "$prompt" \
        '{
          model: $model,
          temperature: 0,
          response_format: {type: "json_object"},
          messages: [
            {role: "system", content: "You are a strict JSON classifier. Return only valid JSON."},
            {role: "user", content: $prompt}
          ]
        }')")" || true
    if [ -n "$resp" ] && [ "$(echo "$resp" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true)" != "" ]; then
      echo "$resp"
      return
    fi
  done
  echo ""
}

fallback_intent() {
  jq -c -n --arg text "${1:-}" \
    '{intent:"unknown",confidence:0.0,action:"clarify",entity:null,normalizedTime:null,reason:"classifier_unavailable",input:$text}'
}

fallback_entity() {
  jq -c -n --arg text "${1:-}" \
    '{entity:"default",confidence:0.0,action:"clarify",reason:"classifier_unavailable",input:$text}'
}

fallback_rerank() {
  jq -c -n --arg query "${1:-}" \
    '{orderedIds:[],confidence:0.0,action:"fallback",reason:"classifier_unavailable",query:$query}'
}

classify_intent() {
  local text="$1"
  local prompt
  prompt="$(cat <<EOF
Classify this user message for a business document assistant.

Message: $text

Return JSON object:
{
  "intent": "document_store|document_search|document_edit|document_delete|reminder_create|reminder_list|reminder_delete|export|email_send|consent|status|memory_set|memory_get|unknown",
  "confidence": 0.0,
  "action": "execute|confirm|clarify",
  "entity": "string-or-null",
  "normalizedTime": "ISO-8601-or-null",
  "memoryKey": "string-or-null",
  "memoryValue": "string-or-null"
}

Memory intents:
- memory_set: User wants to store a fact ("Merke dir dass ich X mag", "Ich mag X")
- memory_get: User asks about stored info ("Was weißt du über mich?", "Was habe ich dir erzählt?")
EOF
)"
  local response
  response="$(call_model "$prompt")"
  if [ -z "$response" ]; then
    fallback_intent "$text"
    return
  fi
  extract_content_json "$response" | jq -c '(if type=="array" then (.[0] // {}) elif type=="object" then . else {} end) | {
    intent:(.intent // "unknown"),
    confidence:(.confidence // 0),
    action:(.action // "clarify"),
    entity:(.entity // null),
    normalizedTime:(.normalizedTime // null),
    memoryKey:(.memoryKey // null),
    memoryValue:(.memoryValue // null)
  }'
}

classify_entity() {
  local text="$1"
  local entities_json="$2"
  local prompt
  prompt="$(cat <<EOF
Select the best matching entity for this message.

Message: $text
Entities: $entities_json

Return JSON:
{
  "entity": "one_of_entities_or_default",
  "confidence": 0.0,
  "action": "execute|confirm|clarify"
}
EOF
)"
  local response
  response="$(call_model "$prompt")"
  if [ -z "$response" ]; then
    fallback_entity "$text"
    return
  fi
  extract_content_json "$response" | jq -c --argjson entities "$entities_json" '
    if type=="array" then (.[0] // {}) elif type=="object" then . else {} end |
    .entity = (if (.entity|type) == "string" and (.entity as $e | $entities | index($e)) != null then .entity else "default" end) |
    {
      entity:(.entity // "default"),
      confidence:(.confidence // 0),
      action:(.action // "clarify")
    }'
}

classify_rerank() {
  local query="$1"
  local candidates_json="$2"
  local prompt
  prompt="$(cat <<EOF
Rank candidate document snippets by relevance to query.

Query: $query
Candidates: $candidates_json

Return JSON:
{
  "orderedIds": ["doc_id_1","doc_id_2"],
  "confidence": 0.0,
  "action": "execute|fallback"
}
EOF
)"
  local response
  response="$(call_model "$prompt")"
  if [ -z "$response" ]; then
    fallback_rerank "$query"
    return
  fi
  extract_content_json "$response" | jq -c '(if type=="array" then (.[0] // {}) elif type=="object" then . else {} end) | {
    orderedIds:(.orderedIds // []),
    confidence:(.confidence // 0),
    action:(.action // "fallback")
  }'
}

CMD="${1:-}"
shift || true

case "$CMD" in
  intent)
    TEXT=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --text) TEXT="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    classify_intent "$TEXT"
    ;;
  entity)
    TEXT=""
    ENTITIES_JSON='["default"]'
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --text) TEXT="$2"; shift 2 ;;
        --entities-json) ENTITIES_JSON="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    classify_entity "$TEXT" "$ENTITIES_JSON"
    ;;
  rerank)
    QUERY=""
    CANDIDATES_JSON="[]"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) QUERY="$2"; shift 2 ;;
        --candidates-json) CANDIDATES_JSON="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    classify_rerank "$QUERY" "$CANDIDATES_JSON"
    ;;
  *)
    usage
    exit 1
    ;;
esac
