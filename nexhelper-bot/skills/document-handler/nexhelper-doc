#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../common/nexhelper-core.sh"

ENTITIES_SCRIPT="$SCRIPT_DIR/../entity-system/nexhelper-entity"
CLASSIFIER_SCRIPT="$SCRIPT_DIR/../classifier/nexhelper-classify"

normalize_float() {
  local value="${1:-0}"
  LC_ALL=C awk -v n="$value" 'BEGIN {printf "%.2f", n+0}'
}

build_fingerprint() {
  local number="$1"
  local supplier="$2"
  local amount="$3"
  local doc_date="$4"
  printf "%s|%s|%s|%s" "${number,,}" "${supplier,,}" "$amount" "$doc_date" | sha256sum | awk '{print $1}'
}

find_duplicate() {
  local fingerprint="$1"
  local file_hash="$2"
  local doc_number="${3:-}"
  local path
  for path in $(nx_list_doc_files); do
    local candidate
    candidate="$(cat "$path")"
    if [ "$(echo "$candidate" | jq -r '.status')" != "active" ]; then
      continue
    fi
    local same_fp
    same_fp="$(echo "$candidate" | jq -r --arg fp "$fingerprint" '.fingerprint == $fp')"
    local same_file_hash
    same_file_hash="$(echo "$candidate" | jq -r --arg fh "$file_hash" '.fileHash == $fh and $fh != ""')"
    local same_number
    same_number="$(echo "$candidate" | jq -r --arg n "$doc_number" '.number == $n and $n != ""')"
    if [ "$same_fp" = "true" ] || [ "$same_file_hash" = "true" ] || [ "$same_number" = "true" ]; then
      echo "$candidate"
      return 0
    fi
  done
  echo "{}"
}

resolve_entity() {
  local entity="$1"
  local source_text="$2"
  if [ -n "$entity" ] && [ "$entity" != "default" ]; then
    echo "$entity"
    return
  fi
  if [ -z "$source_text" ]; then
    echo "default"
    return
  fi
  local entities_json
  entities_json="$("$ENTITIES_SCRIPT" list-json)"
  "$CLASSIFIER_SCRIPT" entity --text "$source_text" --entities-json "$entities_json" | jq -r '.entity // "default"'
}

store_document() {
  local type="$1"
  local amount="$2"
  local entity="$3"
  local supplier="$4"
  local number="$5"
  local doc_date="$6"
  local due_date="$7"
  local category="$8"
  local file_ref="$9"
  local source="${10}"
  local source_text="${11}"
  local ocr_text="${12}"
  local idempotency_key="${13}"

  nx_init_dirs
  local op_id
  op_id="$(nx_op_id doc)"

  if [ -n "$idempotency_key" ] && nx_idempotency_has "$idempotency_key"; then
    nx_idempotency_get "$idempotency_key"
    return
  fi

  amount="$(normalize_float "$amount")"
  local validation_errors="[]"
  if [ -z "$supplier" ]; then
    validation_errors="$(echo "$validation_errors" | jq -c '. + ["missing_supplier"]')"
  fi
  if [ -z "$number" ]; then
    validation_errors="$(echo "$validation_errors" | jq -c '. + ["missing_number"]')"
  fi
  if [ -z "$doc_date" ]; then
    validation_errors="$(echo "$validation_errors" | jq -c '. + ["missing_date"]')"
  fi
  if [ "$amount" = "0.00" ]; then
    validation_errors="$(echo "$validation_errors" | jq -c '. + ["missing_or_zero_amount"]')"
  fi
  local safe_entity
  safe_entity="$(resolve_entity "$entity" "$source_text")"
  if [ -n "$file_ref" ] && [ -f "$file_ref" ]; then
    nx_require_tenant_path "$file_ref"
    local file_size
    file_size="$(wc -c < "$file_ref")"
    if [ "$file_size" -gt $((20 * 1024 * 1024)) ]; then
      validation_errors="$(echo "$validation_errors" | jq -c '. + ["large_file_over_20mb"]')"
    fi
  fi
  if [ -n "$file_ref" ] && [ ! -f "$file_ref" ]; then
    validation_errors="$(echo "$validation_errors" | jq -c '. + ["file_not_found"]')"
  fi
  if [ "$(echo "$validation_errors" | jq 'length')" -gt 0 ]; then
    jq -c -n --arg status "invalid" --arg opId "$op_id" --argjson errors "$validation_errors" \
      '{status:$status,opId:$opId,errors:$errors}'
    return
  fi
  local file_hash
  file_hash="$(nx_hash_file "$file_ref")"
  local fingerprint
  fingerprint="$(build_fingerprint "$number" "$supplier" "$amount" "$doc_date")"
  local duplicate
  duplicate="$(find_duplicate "$fingerprint" "$file_hash" "$number")"
  if [ "$(echo "$duplicate" | jq -r '.id // empty')" != "" ]; then
    jq -c -n --arg status "duplicate" --arg opId "$op_id" --argjson duplicate "$duplicate" \
      '{status:$status,opId:$opId,duplicate:$duplicate}'
    return
  fi

  local doc_id
  doc_id="$(nx_op_id doc)"
  local now
  now="$(nx_now_iso)"
  local payload
  payload="$(jq -c -n \
    --arg id "$doc_id" \
    --arg type "$type" \
    --arg number "$number" \
    --arg supplier "$supplier" \
    --argjson amount "$amount" \
    --arg currency "EUR" \
    --arg date "$doc_date" \
    --arg dueDate "$due_date" \
    --arg category "$category" \
    --arg entity "$safe_entity" \
    --arg fileRef "$file_ref" \
    --arg fileHash "$file_hash" \
    --arg fingerprint "$fingerprint" \
    --arg extractedAt "$now" \
    --arg source "$source" \
    --arg sourceText "$source_text" \
    --arg ocrText "$ocr_text" \
    --arg createdAt "$now" \
    --arg updatedAt "$now" \
    --arg opId "$op_id" \
    '{
      id:$id,
      revision:1,
      status:"active",
      type:$type,
      number:$number,
      supplier:$supplier,
      amount:$amount,
      currency:$currency,
      date:$date,
      dueDate:$dueDate,
      category:$category,
      entity:$entity,
      tags:[$entity],
      fileRef:$fileRef,
      fileHash:$fileHash,
      fingerprint:$fingerprint,
      extractedAt:$extractedAt,
      source:$source,
      sourceText:$sourceText,
      ocrText:$ocrText,
      createdAt:$createdAt,
      updatedAt:$updatedAt,
      deletedAt:null,
      deletedReason:null,
      opId:$opId
    }')"
  nx_write_doc_json "$doc_id" "$payload"

  if [ "$type" = "rechnung" ] && [ "$safe_entity" != "default" ]; then
    "$ENTITIES_SCRIPT" spend "$safe_entity" "$amount" >/dev/null 2>&1 || true
  fi

  local result
  result="$(jq -c -n --arg status "stored" --arg opId "$op_id" --argjson document "$payload" \
    '{status:$status,opId:$opId,document:$document}')"
  if [ -n "$idempotency_key" ]; then
    nx_idempotency_put "$idempotency_key" "$result"
  fi
  nx_log_event "document.store" "$op_id" "success" "$result"
  echo "$result"
}

get_document() {
  local doc_id="$1"
  nx_init_dirs
  nx_load_doc_json "$doc_id"
}

update_document() {
  local doc_id="$1"
  local field="$2"
  local value="$3"
  local reason="$4"
  nx_init_dirs
  if ! nx_doc_exists "$doc_id"; then
    jq -c -n --arg status "not_found" --arg id "$doc_id" '{status:$status,id:$id}'
    return
  fi
  local original
  original="$(nx_load_doc_json "$doc_id")"
  local rev
  rev="$(echo "$original" | jq '.revision + 1')"
  local updated
  updated="$(echo "$original" | jq -c --arg field "$field" --arg value "$value" --arg now "$(nx_now_iso)" --arg reason "$reason" --argjson rev "$rev" '
    .[$field]=$value | .revision=$rev | .updatedAt=$now | .lastUpdateReason=$reason')"
  nx_write_doc_json "$doc_id" "$updated"
  local op_id
  op_id="$(nx_op_id docupd)"
  nx_log_event "document.update" "$op_id" "success" "$(jq -c -n --arg id "$doc_id" --arg field "$field" '{id:$id,field:$field}')"
  jq -c -n --arg status "updated" --arg id "$doc_id" --arg field "$field" --arg value "$value" \
    '{status:$status,id:$id,field:$field,value:$value}'
}

soft_delete_document() {
  local doc_id="$1"
  local reason="$2"
  nx_init_dirs
  if ! nx_doc_exists "$doc_id"; then
    jq -c -n --arg status "not_found" --arg id "$doc_id" '{status:$status,id:$id}'
    return
  fi
  local original
  original="$(nx_load_doc_json "$doc_id")"
  local rev
  rev="$(echo "$original" | jq '.revision + 1')"
  local updated
  updated="$(echo "$original" | jq -c --arg now "$(nx_now_iso)" --arg reason "$reason" --argjson rev "$rev" '
    .status="deleted" | .deletedAt=$now | .deletedReason=$reason | .revision=$rev | .updatedAt=$now')"
  nx_write_doc_json "$doc_id" "$updated"
  local op_id
  op_id="$(nx_op_id docdel)"
  nx_log_event "document.delete" "$op_id" "success" "$(jq -c -n --arg id "$doc_id" --arg reason "$reason" '{id:$id,reason:$reason}')"
  jq -c -n --arg status "deleted" --arg id "$doc_id" '{status:$status,id:$id}'
}

hard_delete_document() {
  local doc_id="$1"
  nx_init_dirs
  local file
  file="$(nx_doc_path_by_id "$doc_id")"
  if [ ! -f "$file" ]; then
    jq -c -n --arg status "not_found" --arg id "$doc_id" '{status:$status,id:$id}'
    return
  fi
  nx_require_tenant_path "$file"
  rm -f "$file"
  local op_id
  op_id="$(nx_op_id dochwipe)"
  nx_log_event "document.hard_delete" "$op_id" "success" "$(jq -c -n --arg id "$doc_id" '{id:$id}')"
  jq -c -n --arg status "hard_deleted" --arg id "$doc_id" '{status:$status,id:$id}'
}

restore_document() {
  local doc_id="$1"
  nx_init_dirs
  if ! nx_doc_exists "$doc_id"; then
    jq -c -n --arg status "not_found" --arg id "$doc_id" '{status:$status,id:$id}'
    return
  fi
  local original
  original="$(nx_load_doc_json "$doc_id")"
  local rev
  rev="$(echo "$original" | jq '.revision + 1')"
  local updated
  updated="$(echo "$original" | jq -c --arg now "$(nx_now_iso)" --argjson rev "$rev" '
    .status="active" | .deletedAt=null | .deletedReason=null | .revision=$rev | .updatedAt=$now')"
  nx_write_doc_json "$doc_id" "$updated"
  jq -c -n --arg status "restored" --arg id "$doc_id" '{status:$status,id:$id}'
}

collect_results() {
  local query="$1"
  local entity="$2"
  local type="$3"
  local date_from="$4"
  local date_to="$5"
  local include_deleted="$6"

  local arr="[]"
  local path
  for path in $(nx_list_doc_files); do
    local doc
    doc="$(cat "$path")"
    local status
    status="$(echo "$doc" | jq -r '.status // "active"')"
    if [ "$include_deleted" != "true" ] && [ "$status" != "active" ]; then
      continue
    fi
    local d_date
    d_date="$(echo "$doc" | jq -r '.date // ""')"
    if ! nx_within_date_range "$d_date" "$date_from" "$date_to"; then
      continue
    fi
    if [ -n "$entity" ] && [ "$entity" != "all" ]; then
      if [ "$(echo "$doc" | jq -r --arg e "$entity" '.entity == $e')" != "true" ]; then
        continue
      fi
    fi
    if [ -n "$type" ] && [ "$type" != "all" ]; then
      if [ "$(echo "$doc" | jq -r --arg t "$type" '.type == $t')" != "true" ]; then
        continue
      fi
    fi
    if [ -n "$query" ]; then
      local hay
      hay="$(echo "$doc" | jq -r '[.number,.supplier,.category,.type,.entity,.ocrText,.sourceText] | map(. // "") | join(" ")' | tr '[:upper:]' '[:lower:]')"
      local needle
      needle="$(echo "$query" | tr '[:upper:]' '[:lower:]')"
      if [[ "$hay" != *"$needle"* ]]; then
        continue
      fi
    fi
    arr="$(echo "$arr" | jq -c --argjson d "$doc" '. + [$d]')"
  done
  echo "$arr"
}

search_documents() {
  local query="$1"
  local entity="$2"
  local type="$3"
  local date_from="$4"
  local date_to="$5"
  local limit="$6"
  local semantic="$7"
  local include_deleted="$8"

  nx_init_dirs
  local results
  results="$(collect_results "$query" "$entity" "$type" "$date_from" "$date_to" "$include_deleted")"
  if [ "$semantic" = "true" ] && [ "$(echo "$results" | jq 'length')" -gt 1 ] && [ -n "$query" ]; then
    local candidates
    candidates="$(echo "$results" | jq -c '[.[] | {id:.id,text:([.number,.supplier,.category,.type,.ocrText] | map(. // "") | join(" "))}]')"
    local rerank
    rerank="$("$CLASSIFIER_SCRIPT" rerank --query "$query" --candidates-json "$candidates")"
    local ordered
    ordered="$(echo "$rerank" | jq -c '.orderedIds // []')"
    if [ "$(echo "$ordered" | jq 'length')" -gt 0 ]; then
      results="$(echo "$results" | jq -c --argjson ordered "$ordered" '
        sort_by((.id as $id | ($ordered | index($id))) // 999999)')"
    fi
  fi
  echo "$results" | jq -c --argjson limit "$limit" '.[:$limit]'
}

list_documents() {
  local limit="$1"
  local include_deleted="$2"
  search_documents "" "all" "all" "" "" "$limit" "false" "$include_deleted"
}

stats_documents() {
  nx_init_dirs
  local results
  results="$(collect_results "" "all" "all" "" "" "false")"
  jq -c -n --argjson docs "$results" '{
    documents: ($docs | length),
    totalAmount: ($docs | map(.amount // 0) | add // 0),
    byType: ($docs | group_by(.type) | map({type:.[0].type,count:length,total:(map(.amount // 0) | add // 0)})),
    byEntity: ($docs | group_by(.entity) | map({entity:.[0].entity,count:length,total:(map(.amount // 0) | add // 0)}))
  }'
}

purge_deleted() {
  local older_than_days="$1"
  nx_init_dirs
  local now_ts
  now_ts="$(date +%s)"
  local purged=0
  local path
  for path in $(nx_list_doc_files); do
    local doc
    doc="$(cat "$path")"
    if [ "$(echo "$doc" | jq -r '.status')" != "deleted" ]; then
      continue
    fi
    local deleted_at
    deleted_at="$(echo "$doc" | jq -r '.deletedAt // ""')"
    if [ -z "$deleted_at" ]; then
      continue
    fi
    local deleted_ts
    deleted_ts="$(date -d "$deleted_at" +%s 2>/dev/null || echo 0)"
    local age_days
    age_days="$(((now_ts - deleted_ts) / 86400))"
    if [ "$age_days" -ge "$older_than_days" ]; then
      nx_require_tenant_path "$path"
      rm -f "$path"
      purged=$((purged + 1))
    fi
  done
  jq -c -n --arg status "purged" --argjson count "$purged" '{status:$status,count:$count}'
}

usage() {
  echo "NexHelper Canonical Document Handler"
  echo ""
  echo "Commands:"
  echo "  store --type <type> --amount <value> --supplier <name> --number <nr> --date <YYYY-MM-DD> [--entity <id>] [--due-date <YYYY-MM-DD>] [--category <name>] [--file <path>] [--source <telegram|whatsapp|system>] [--source-text <text>] [--ocr-text <text>] [--idempotency-key <key>]"
  echo "  get <doc_id>"
  echo "  search --query <text> [--entity <id>] [--type <type>] [--date-from <YYYY-MM-DD>] [--date-to <YYYY-MM-DD>] [--limit <n>] [--semantic true|false] [--include-deleted true|false]"
  echo "  list [--limit <n>] [--include-deleted true|false]"
  echo "  update <doc_id> --field <field> --value <value> [--reason <text>]"
  echo "  delete <doc_id> [--reason <text>]"
  echo "  restore <doc_id>"
  echo "  hard-delete <doc_id>"
  echo "  purge-deleted --days <n>"
  echo "  stats"
}

CMD="${1:-}"
shift || true

case "$CMD" in
  store)
    TYPE="rechnung"
    AMOUNT="0"
    ENTITY="default"
    SUPPLIER=""
    NUMBER=""
    DOC_DATE=""
    DUE_DATE=""
    CATEGORY=""
    FILE_REF=""
    SOURCE="telegram"
    SOURCE_TEXT=""
    OCR_TEXT=""
    IDEMPOTENCY_KEY=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --type) TYPE="$2"; shift 2 ;;
        --amount) AMOUNT="$2"; shift 2 ;;
        --entity) ENTITY="$2"; shift 2 ;;
        --supplier) SUPPLIER="$2"; shift 2 ;;
        --number) NUMBER="$2"; shift 2 ;;
        --date) DOC_DATE="$2"; shift 2 ;;
        --due-date) DUE_DATE="$2"; shift 2 ;;
        --category) CATEGORY="$2"; shift 2 ;;
        --file) FILE_REF="$2"; shift 2 ;;
        --source) SOURCE="$2"; shift 2 ;;
        --source-text) SOURCE_TEXT="$2"; shift 2 ;;
        --ocr-text) OCR_TEXT="$2"; shift 2 ;;
        --idempotency-key) IDEMPOTENCY_KEY="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    store_document "$TYPE" "$AMOUNT" "$ENTITY" "$SUPPLIER" "$NUMBER" "$DOC_DATE" "$DUE_DATE" "$CATEGORY" "$FILE_REF" "$SOURCE" "$SOURCE_TEXT" "$OCR_TEXT" "$IDEMPOTENCY_KEY"
    ;;
  get)
    get_document "${1:-}"
    ;;
  search)
    QUERY=""
    ENTITY="all"
    TYPE="all"
    DATE_FROM=""
    DATE_TO=""
    LIMIT="25"
    SEMANTIC="true"
    INCLUDE_DELETED="false"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) QUERY="$2"; shift 2 ;;
        --entity) ENTITY="$2"; shift 2 ;;
        --type) TYPE="$2"; shift 2 ;;
        --date-from) DATE_FROM="$2"; shift 2 ;;
        --date-to) DATE_TO="$2"; shift 2 ;;
        --limit) LIMIT="$2"; shift 2 ;;
        --semantic) SEMANTIC="$2"; shift 2 ;;
        --include-deleted) INCLUDE_DELETED="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    search_documents "$QUERY" "$ENTITY" "$TYPE" "$DATE_FROM" "$DATE_TO" "$LIMIT" "$SEMANTIC" "$INCLUDE_DELETED"
    ;;
  list)
    LIMIT="25"
    INCLUDE_DELETED="false"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --limit) LIMIT="$2"; shift 2 ;;
        --include-deleted) INCLUDE_DELETED="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    list_documents "$LIMIT" "$INCLUDE_DELETED"
    ;;
  update)
    DOC_ID="${1:-}"
    shift || true
    FIELD=""
    VALUE=""
    REASON="manual_update"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --field) FIELD="$2"; shift 2 ;;
        --value) VALUE="$2"; shift 2 ;;
        --reason) REASON="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    update_document "$DOC_ID" "$FIELD" "$VALUE" "$REASON"
    ;;
  delete)
    DOC_ID="${1:-}"
    shift || true
    REASON="user_request"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --reason) REASON="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    soft_delete_document "$DOC_ID" "$REASON"
    ;;
  restore)
    restore_document "${1:-}"
    ;;
  hard-delete)
    hard_delete_document "${1:-}"
    ;;
  purge-deleted)
    DAYS="30"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --days) DAYS="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    purge_deleted "$DAYS"
    ;;
  stats)
    stats_documents
    ;;
  *)
    usage
    exit 1
    ;;
esac
