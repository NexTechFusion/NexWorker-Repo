{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "nexhelper-entity",
  "description": "Entity management and budget tracking for NexHelper",
  "version": "1.0.0",
  "commands": {
    "detect": {
      "description": "Detect entity from user message",
      "input": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10000,
            "description": "User message mentioning entity"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "description": "Same as classifier entity output",
        "properties": {
          "entity": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "action": { "type": "string", "enum": ["execute", "confirm", "clarify"] },
          "reason": { "type": ["string", "null"] },
          "input": { "type": "string" }
        },
        "required": ["entity", "confidence", "action"]
      }
    },
    "tag": {
      "description": "Tag a document with an entity",
      "input": {
        "type": "object",
        "required": ["doc_id", "entity_id"],
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "Document ID to tag"
          },
          "entity_id": {
            "type": "string",
            "description": "Entity ID to tag with"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "doc_id": { "type": "string" },
          "entity": { "type": "string" },
          "reason": { "type": "string" }
        },
        "required": ["success", "doc_id", "entity"]
      }
    },
    "budget": {
      "description": "Get budget status for entity",
      "input": {
        "type": "object",
        "properties": {
          "entity_id": {
            "type": "string",
            "default": "default",
            "description": "Entity ID (defaults to 'default')"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "entity": { "type": "string" },
          "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
          "spent": { "type": "number" },
          "budget": { "type": "number" },
          "thresholdsNotified": {
            "type": "array",
            "items": { "type": "string" }
          },
          "lastUpdated": { "type": "string", "format": "date-time" }
        },
        "required": ["entity", "period", "spent", "budget"]
      }
    },
    "spend": {
      "description": "Record spending for entity",
      "input": {
        "type": "object",
        "required": ["entity_id", "amount"],
        "properties": {
          "entity_id": {
            "type": "string",
            "description": "Entity ID"
          },
          "amount": {
            "type": "number",
            "minimum": 0,
            "description": "Amount spent"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "entity": { "type": "string" },
          "spent": { "type": "number" },
          "budget": { "type": "number" }
        },
        "required": ["entity", "spent", "budget"]
      }
    },
    "check": {
      "description": "Check all entity budgets for threshold alerts",
      "input": {
        "type": "object",
        "additionalProperties": false
      },
      "output": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "entity": { "type": "string" },
            "percent": { "type": "number" },
            "threshold": { "type": "string" },
            "spent": { "type": "number" },
            "budget": { "type": "number" }
          }
        }
      }
    },
    "list": {
      "description": "List all entities (human-readable)",
      "input": {
        "type": "object",
        "additionalProperties": false
      },
      "output": {
        "type": "string",
        "description": "Plain text list of entities"
      }
    },
    "list-json": {
      "description": "List all entities (JSON array)",
      "input": {
        "type": "object",
        "additionalProperties": false
      },
      "output": {
        "type": "array",
        "items": { "type": "string" },
        "description": "JSON array of entity IDs"
      }
    }
  },
  "environment": {
    "required": ["CONFIG_DIR", "NX_STORAGE_DIR"],
    "optional": ["ENTITIES_CONFIG"]
  },
  "dependencies": {
    "detect": ["classifier"],
    "tag": ["document-handler"]
  },
  "errors": {
    "entity_not_found": "Entity ID does not exist",
    "invalid_amount": "Amount must be a positive number",
    "doc_not_found": "Document ID not found",
    "budget_disabled": "No budget configured for entity"
  }
}