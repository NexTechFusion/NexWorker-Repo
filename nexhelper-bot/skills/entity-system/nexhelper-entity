#!/bin/bash
# Entity Management CLI for NexHelper
# Usage: nexhelper-entity <command> [args]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${CONFIG_DIR:-/app/config}"
STORAGE_DIR="${STORAGE_DIR:-/root/.openclaw/workspace/storage}"
ENTITIES_CONFIG="$CONFIG_DIR/entities.yaml"
ENTITIES_STORAGE="$STORAGE_DIR/entities"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Ensure directories exist
init_dirs() {
    mkdir -p "$ENTITIES_STORAGE"
    if [ ! -f "$ENTITIES_CONFIG" ]; then
        log_warn "No entities.yaml found, creating default..."
        cat <<EOF > "$ENTITIES_CONFIG"
entities:
  - id: default
    name: "Default"
    budget: null
    budgetPeriod: null
    aliases: []
    active: true
    notifyOnOverBudget: false
EOF
    fi
}

# Get current period (YYYY-MM)
get_period() {
    date +%Y-%m
}

# Load entities config
load_entities() {
    if [ -f "$ENTITIES_CONFIG" ]; then
        cat "$ENTITIES_CONFIG"
    else
        echo '{"entities": []}'
    fi
}

# Find entity by alias in text
detect_entity() {
    local text="$1"
    local entities
    entities=$(load_entities)
    
    # Check each entity
    while IFS= read -r entity_id; do
        # Skip empty
        [ -z "$entity_id" ] && continue
        
        # Get name for this entity
        local name
        name=$(echo "$entities" | sed -n "/- id: $entity_id/,/^- /p" | grep "name:" | head -1 | sed 's/.*name: "*\(.*\)"*/\1/' | tr -d ' ')
        
        # Check if entity name appears in text
        if [ -n "$name" ] && echo "$text" | grep -qi "$name"; then
            echo "$entity_id"
            return 0
        fi
        
        # Also check id itself (e.g., "marketing")
        if echo "$text" | grep -qi "$entity_id"; then
            echo "$entity_id"
            return 0
        fi
        
        # Get aliases for this entity
        local aliases
        aliases=$(echo "$entities" | sed -n "/- id: $entity_id/,/^- /p" | grep -oP 'aliases: \[\K[^\]]+' || echo "")
        
        # Check if any alias matches
        for alias in $(echo "$aliases" | tr ',' '\n' | tr -d '"' | tr -d ' '); do
            if [ -n "$alias" ] && echo "$text" | grep -qi "$alias"; then
                echo "$entity_id"
                return 0
            fi
        done
    done < <(echo "$entities" | grep -oP '^\s+- id: \K[^$]+')
    
    echo "default"
}

# Get entity budget stats
get_budget() {
    local entity_id="${1:-default}"
    local stats_file="$ENTITIES_STORAGE/$entity_id/stats.json"
    
    if [ -f "$stats_file" ]; then
        cat "$stats_file"
    else
        # Initialize stats file
        local budget
        budget=$(load_entities | grep -A5 "id: $entity_id" | grep "budget:" | awk '{print $2}' || echo "0")
        
        cat <<EOF > "$stats_file"
{
  "period": "$(get_period)",
  "spent": 0,
  "budget": $budget,
  "transactions": [],
  "lastUpdated": "$(date -Iseconds)"
}
EOF
        cat "$stats_file"
    fi
}

# Add spending to entity
spend() {
    local entity_id="$1"
    local amount="$2"
    
    if [ -z "$entity_id" ] || [ -z "$amount" ]; then
        echo "Usage: spend <entity_id> <amount>"
        exit 1
    fi
    
    local stats_file="$ENTITIES_STORAGE/$entity_id/stats.json"
    local current_period=$(get_period)
    
    # Get current stats or initialize
    local stats
    stats=$(get_budget "$entity_id")
    
    local spent
    spent=$(echo "$stats" | grep -oP '"spent": \K[^,]+' || echo "0")
    local period
    period=$(echo "$stats" | grep -oP '"period": "\K[^"]+' || echo "")
    local budget
    budget=$(echo "$stats" | grep -oP '"budget": \K[^,]+' || echo "0")
    
    # Reset if new period
    if [ "$period" != "$current_period" ]; then
        spent=0
        period="$current_period"
    fi
    
    # Add amount (can be negative for credits) - use C locale for numeric formatting
    spent=$(LC_ALL=C awk '{printf "%.2f", $1+$2}' <<< "$spent $amount")
    
    # Update stats
    cat <<EOF > "$stats_file"
{
  "period": "$period",
  "spent": $spent,
  "budget": $budget,
  "transactions": [],
  "lastUpdated": "$(date -Iseconds)"
}
EOF
    
    # Calculate percentage - use C locale
    if [ "$budget" != "null" ] && [ "$budget" != "0" ]; then
        local percent
        percent=$(LC_ALL=C awk '{printf "%.2f", $1/$2*100}' <<< "$spent $budget")
        echo "✅ $entity_id: €$spent / €$budget ($percent%)"
    else
        echo "✅ $entity_id: €$spent (no budget set)"
    fi
}

# Check all entities for budget alerts
check_budgets() {
    local entities
    entities=$(load_entities)
    local alerts=()
    local current_period=$(get_period)
    
    # Get all entity IDs (skip default if no budget)
    local entity_ids
    entity_ids=$(echo "$entities" | grep -oP '^\s+- id: \K[^$]+' | grep -v "^$")
    
    for entity_id in $entity_ids; do
        # Skip if no budget
        local entity_config
        entity_config=$(echo "$entities" | sed -n "/- id: $entity_id/,/^- /p" | head -10)
        local budget
        budget=$(echo "$entity_config" | grep "budget:" | awk '{print $2}' | tr -d ' ')
        
        if [ "$budget" = "null" ] || [ -z "$budget" ]; then
            continue
        fi
        
        # Get current spending
        local stats_file="$ENTITIES_STORAGE/$entity_id/stats.json"
        if [ -f "$stats_file" ]; then
            local spent
            spent=$(cat "$stats_file" | grep -oP '"spent": \K[^,]+')
        else
            spent=0
        fi
        
        # Calculate percentage - use C locale
        local percent
        percent=$(LC_ALL=C awk '{printf "%.2f", $1/$2*100}' <<< "$spent $budget")
        
        # Check thresholds - compare as numbers
        local notify
        notify=$(echo "$entity_config" | grep "notifyOnOverBudget:" | awk '{print $2}')
        
        if [ "$notify" = "true" ]; then
            if LC_ALL=C awk -v p="$percent" 'BEGIN {exit !(p >= 100)}'; then
                alerts+=("🚨 $entity_id: BUDGET EXCEEDED! €$spent / €$budget")
            elif LC_ALL=C awk -v p="$percent" 'BEGIN {exit !(p >= 90)}'; then
                alerts+=("⚠️ $entity_id: 90% reached (€$spent / €$budget)")
            elif LC_ALL=C awk -v p="$percent" 'BEGIN {exit !(p >= 75)}'; then
                alerts+=("⚡ $entity_id: 75% reached (€$spent / €$budget)")
            fi
        fi
    done
    
    if [ ${#alerts[@]} -eq 0 ]; then
        echo "[]"
    else
        printf '%s\n' "${alerts[@]}"
    fi
}

# List all entities
list_entities() {
    local entities
    entities=$(load_entities)
    
    echo "$entities" | grep -oP '^\s+- id: \K[^$]+' | while read -r id; do
        local name
        name=$(echo "$entities" | sed -n "/- id: $id/,/^- /p" | grep "name:" | head -1 | sed 's/.*name: "\?"\(.*\)"\?/\1/')
        local budget
        budget=$(echo "$entities" | sed -n "/- id: $id/,/^- /p" | grep "budget:" | head -1 | awk '{print $2}')
        echo "$id: $name (Budget: $budget)"
    done
}

# Tag a document (update its entity)
tag_document() {
    local doc_id="$1"
    local entity_id="$2"
    
    if [ -z "$doc_id" ] || [ -z "$entity_id" ]; then
        echo "Usage: tag <doc_id> <entity_id>"
        exit 1
    fi
    
    # This would update the document in memory
    # For now, just echo what would happen
    echo "Would tag document $doc_id with entity $entity_id"
}

# Main command handler
case "${1:-}" in
    detect)
        init_dirs
        detect_entity "$2"
        ;;
    tag)
        init_dirs
        tag_document "$2" "$3"
        ;;
    budget)
        init_dirs
        get_budget "$2"
        ;;
    spend)
        init_dirs
        spend "$2" "$3"
        ;;
    check)
        init_dirs
        check_budgets
        ;;
    list)
        init_dirs
        list_entities
        ;;
    init)
        init_dirs
        log_info "Entity system initialized"
        ;;
    *)
        echo "NexHelper Entity Management"
        echo ""
        echo "Usage: nexhelper-entity <command> [args]"
        echo ""
        echo "Commands:"
        echo "  detect <text>      Detect entity from text"
        echo "  tag <doc_id> <entity>  Tag document with entity"
        echo "  budget [entity]    Get budget status"
        echo "  spend <entity> <amount>  Add expense"
        echo "  check              Check all budgets for alerts"
        echo "  list               List all entities"
        echo "  init               Initialize directories"
        ;;
esac
