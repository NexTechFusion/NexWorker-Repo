#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../common/nexhelper-core.sh"

CONFIG_DIR="${CONFIG_DIR:-/app/config}"
ENTITIES_CONFIG="$CONFIG_DIR/entities.yaml"
ENTITIES_STORAGE="$NX_STORAGE_DIR/entities"
CLASSIFIER_SCRIPT="$SCRIPT_DIR/../classifier/nexhelper-classify"
DOC_SCRIPT="$SCRIPT_DIR/../document-handler/nexhelper-doc"

init_dirs() {
  mkdir -p "$ENTITIES_STORAGE"
  nx_require_tenant_path "$ENTITIES_STORAGE"
  if [ ! -f "$ENTITIES_CONFIG" ]; then
    cat <<EOF > "$ENTITIES_CONFIG"
entities:
  - id: default
    name: "Default"
    budget: null
    budgetPeriod: null
    aliases: []
    active: true
    notifyOnOverBudget: false
EOF
  fi
}

get_period() {
  date +%Y-%m
}

list_entities_json() {
  awk '/- id:/ {print $3}' "$ENTITIES_CONFIG" | jq -R -s -c 'split("\n") | map(select(length>0))'
}

entity_block() {
  local id="$1"
  awk -v target="$id" '
    $0 ~ "- id: "target"$" {in_block=1}
    in_block {print}
    in_block && /^  - id:/ && $0 !~ "- id: "target"$" {exit}
  ' "$ENTITIES_CONFIG"
}

entity_budget_from_config() {
  local id="$1"
  local budget
  budget="$(entity_block "$id" | awk '/budget:/ {print $2; exit}')"
  if [ -z "$budget" ]; then
    echo "0"
  else
    echo "$budget"
  fi
}

entity_notify_from_config() {
  local id="$1"
  entity_block "$id" | awk '/notifyOnOverBudget:/ {print $2; exit}'
}

stats_file_for() {
  local id="$1"
  echo "$ENTITIES_STORAGE/$id/stats.json"
}

get_budget() {
  local entity_id="${1:-default}"
  local stats_file
  stats_file="$(stats_file_for "$entity_id")"
  mkdir -p "$ENTITIES_STORAGE/$entity_id"
  if [ ! -f "$stats_file" ]; then
    local budget
    budget="$(entity_budget_from_config "$entity_id")"
    cat <<EOF > "$stats_file"
{
  "entity":"$entity_id",
  "period":"$(get_period)",
  "spent":0,
  "budget":$budget,
  "thresholdsNotified":[],
  "lastUpdated":"$(nx_now_iso)"
}
EOF
  fi
  cat "$stats_file"
}

detect_entity() {
  local text="$1"
  local entities_json
  entities_json="$(list_entities_json)"
  "$CLASSIFIER_SCRIPT" entity --text "$text" --entities-json "$entities_json"
}

spend() {
  local entity_id="$1"
  local amount="${2:-0}"
  local stats
  stats="$(get_budget "$entity_id")"
  local current_period
  current_period="$(get_period)"
  local period
  period="$(echo "$stats" | jq -r '.period')"
  local budget
  budget="$(echo "$stats" | jq -r '.budget')"
  local spent
  spent="$(echo "$stats" | jq -r '.spent')"
  if [ "$period" != "$current_period" ]; then
    spent="0"
    period="$current_period"
  fi
  local updated_spent
  updated_spent="$(LC_ALL=C awk -v a="$spent" -v b="$amount" 'BEGIN {printf "%.2f", a+b}')"
  local updated
  updated="$(echo "$stats" | jq -c \
    --arg period "$period" \
    --argjson spent "$updated_spent" \
    --arg now "$(nx_now_iso)" \
    '.period=$period | .spent=$spent | .lastUpdated=$now')"
  printf "%s\n" "$updated" > "$(stats_file_for "$entity_id")"
  jq -c -n --arg entity "$entity_id" --argjson spent "$updated_spent" --argjson budget "${budget:-0}" \
    '{entity:$entity,spent:$spent,budget:$budget}'
}

tag_document() {
  local doc_id="$1"
  local entity_id="$2"
  "$DOC_SCRIPT" update "$doc_id" --field entity --value "$entity_id" --reason "entity_tag"
}

check_budgets() {
  local entities
  entities="$(list_entities_json)"
  local alerts="[]"
  local entity_id
  for entity_id in $(echo "$entities" | jq -r '.[]'); do
    local notify
    notify="$(entity_notify_from_config "$entity_id")"
    if [ "$notify" != "true" ]; then
      continue
    fi
    local stats
    stats="$(get_budget "$entity_id")"
    local spent budget
    spent="$(echo "$stats" | jq -r '.spent')"
    budget="$(echo "$stats" | jq -r '.budget')"
    if [ "$budget" = "null" ] || [ "$budget" = "0" ]; then
      continue
    fi
    local percent
    percent="$(LC_ALL=C awk -v s="$spent" -v b="$budget" 'BEGIN {printf "%.2f", (s/b)*100}')"
    local threshold=""
    if LC_ALL=C awk -v p="$percent" 'BEGIN {exit !(p >= 100)}'; then
      threshold="100"
    elif LC_ALL=C awk -v p="$percent" 'BEGIN {exit !(p >= 90)}'; then
      threshold="90"
    elif LC_ALL=C awk -v p="$percent" 'BEGIN {exit !(p >= 75)}'; then
      threshold="75"
    fi
    if [ -n "$threshold" ]; then
      local exists
      exists="$(echo "$stats" | jq -r --arg t "$threshold" '.thresholdsNotified | index($t) != null')"
      if [ "$exists" != "true" ]; then
        alerts="$(echo "$alerts" | jq -c --arg entity "$entity_id" --arg threshold "$threshold" --argjson spent "$spent" --argjson budget "$budget" '. + [{entity:$entity,threshold:$threshold,spent:$spent,budget:$budget}]')"
        local updated
        updated="$(echo "$stats" | jq -c --arg t "$threshold" --arg now "$(nx_now_iso)" '.thresholdsNotified += [$t] | .lastUpdated=$now')"
        printf "%s\n" "$updated" > "$(stats_file_for "$entity_id")"
      fi
    fi
  done
  echo "$alerts"
}

list_entities_text() {
  local id
  for id in $(list_entities_json | jq -r '.[]'); do
    local budget
    budget="$(entity_budget_from_config "$id")"
    echo "$id (budget: $budget)"
  done
}

usage() {
  echo "NexHelper Entity Management"
  echo "Commands:"
  echo "  detect <text>"
  echo "  tag <doc_id> <entity>"
  echo "  budget [entity]"
  echo "  spend <entity> <amount>"
  echo "  check"
  echo "  list"
  echo "  list-json"
}

CMD="${1:-}"
shift || true
init_dirs

case "$CMD" in
  detect) detect_entity "${1:-}" ;;
  tag) tag_document "${1:-}" "${2:-}" ;;
  budget) get_budget "${1:-default}" ;;
  spend) spend "${1:-default}" "${2:-0}" ;;
  check) check_budgets ;;
  list) list_entities_text ;;
  list-json) list_entities_json ;;
  *) usage; exit 1 ;;
esac
