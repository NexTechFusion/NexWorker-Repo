#!/bin/bash
# nexhelper-set-reminder - Schedule a reminder via OpenClaw cron
#
# Strategy: try CLI first (registers in Gateway memory, clean dedup).
# If CLI fails (WebSocket timeout on some deployments), fall back to
# direct jobs.json write. Canonical reminder is always created for
# listing/auditing regardless of which path succeeds.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")" 2>/dev/null || dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../common/nexhelper-core.sh"

TEXT=""
TIME_ARG=""
USER_ID=""
CHANNEL="last"
IDEMPOTENCY_KEY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --text) TEXT="$2"; shift 2 ;;
    --time) TIME_ARG="$2"; shift 2 ;;
    --user) USER_ID="$2"; shift 2 ;;
    --channel) CHANNEL="${2:-last}"; shift 2 ;;
    --idempotency-key) IDEMPOTENCY_KEY="$2"; shift 2 ;;
    -h|--help)
      echo "nexhelper-set-reminder - Schedule a reminder via OpenClaw cron"
      echo ""
      echo "Usage:"
      echo "  nexhelper-set-reminder --text 'Meeting' --time '2026-03-14T09:00:00' --user 579539601"
      echo "  nexhelper-set-reminder --text 'Call' --time '5m' --user 579539601"
      echo "  nexhelper-set-reminder --text 'Boss callen' --time 'in 10 Minuten' --user 579539601"
      echo ""
      echo "Options:"
      echo "  --text <text>        Reminder text (required)"
      echo "  --time <iso|dur>     ISO timestamp, duration (5m, 1h), or natural language (required)"
      echo "  --user <id>          Recipient user/chat ID (required)"
      echo "  --channel <ch>       Delivery channel (default: last)"
      echo "  --idempotency-key <k> Idempotency key"
      echo ""
      echo "Supported time formats:"
      echo "  - Simple: 5m, 1h, 30s, 1d"
      echo "  - German: 'in 5 Minuten', 'in einer Stunde', 'morgen', 'übermorgen'"
      echo "  - English: 'in 5 minutes', 'in an hour', 'tomorrow', 'day after tomorrow'"
      echo "  - ISO: 2026-03-17T15:00:00"
      exit 0
      ;;
    *) shift ;;
  esac
done

if [ -z "$TEXT" ] || [ -z "$TIME_ARG" ] || [ -z "$USER_ID" ]; then
  echo '{"status":"error","message":"Missing required args: --text, --time, --user"}' >&2
  exit 1
fi

ABSOLUTE_TIME="$(nx_parse_relative_time "$TIME_ARG")"

if [[ ! "$ABSOLUTE_TIME" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T ]]; then
  echo "{\"status\":\"error\",\"message\":\"Failed to parse time: $TIME_ARG\"}" >&2
  exit 1
fi

JOB_NAME="reminder-$(date +%s)-$$"
MESSAGE_TEXT="⏰ ERINNERUNG: $TEXT"
CREATED_VIA=""
JOB_ID=""

# --- Path 1: CLI (preferred — registers in Gateway memory) ---
CRON_RESULT="$(timeout 10 openclaw cron add \
  --name "$JOB_NAME" \
  --at "$ABSOLUTE_TIME" \
  --session isolated \
  --message "$MESSAGE_TEXT" \
  --announce \
  --channel "$CHANNEL" \
  --to "$USER_ID" \
  --delete-after-run \
  --json 2>/dev/null || echo "{}")"

JOB_ID="$(echo "$CRON_RESULT" | jq -r '.id // .jobId // empty' 2>/dev/null || echo "")"

if [ -n "$JOB_ID" ]; then
  CREATED_VIA="cli"
else
  # --- Path 2: Direct jobs.json write (fallback for WebSocket timeout) ---
  JOBS_FILE="$HOME/.openclaw/cron/jobs.json"
  mkdir -p "$(dirname "$JOBS_FILE")" 2>/dev/null || true

  JOB_ID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null | tr '[:upper:]' '[:lower:]' || echo "job-$(date +%s)-$$")"
  NOW_MS="$(($(date +%s) * 1000))"

  NEW_JOB="$(jq -c -n \
    --arg id "$JOB_ID" \
    --arg name "$JOB_NAME" \
    --argjson createdAtMs "$NOW_MS" \
    --argjson updatedAtMs "$NOW_MS" \
    --arg atTime "$ABSOLUTE_TIME" \
    --arg message "$MESSAGE_TEXT" \
    --arg channel "$CHANNEL" \
    --arg toUser "$USER_ID" \
    '{
      id: $id,
      name: $name,
      createdAtMs: $createdAtMs,
      updatedAtMs: $updatedAtMs,
      schedule: { kind: "at", at: $atTime },
      sessionTarget: "isolated",
      deleteAfterRun: true,
      payload: { kind: "agentTurn", message: $message, lightContext: true },
      delivery: { mode: "announce", channel: $channel, to: $toUser, bestEffort: true }
    }')"

  if [ -f "$JOBS_FILE" ]; then
    EXISTING="$(cat "$JOBS_FILE" 2>/dev/null || echo '{"version":1,"jobs":[]}')"
  else
    EXISTING='{"version":1,"jobs":[]}'
  fi
  echo "$EXISTING" | jq --argjson j "$NEW_JOB" '.jobs += [$j]' > "$JOBS_FILE"

  CREATED_VIA="file"
fi

# Always create canonical reminder for listing/auditing.
# Tag with cronJobName so nexhelper-reminder-sync can skip it.
CANONICAL_ID=""
if command -v nexhelper-reminder >/dev/null 2>&1; then
  CANONICAL_RESULT="$(nexhelper-reminder create --user "$USER_ID" --text "$TEXT" --datetime "$TIME_ARG" --channel "$CHANNEL" 2>/dev/null || echo "{}")"
  CANONICAL_ID="$(echo "$CANONICAL_RESULT" | jq -r '.reminder.id // empty' 2>/dev/null || echo "")"
fi

jq -c -n \
  --arg status "ok" \
  --arg jobId "$JOB_ID" \
  --arg jobName "$JOB_NAME" \
  --arg canonicalId "$CANONICAL_ID" \
  --arg createdVia "$CREATED_VIA" \
  --arg text "$TEXT" \
  --arg time "$ABSOLUTE_TIME" \
  --arg originalTime "$TIME_ARG" \
  --arg user "$USER_ID" \
  --arg channel "$CHANNEL" \
  '{status:$status, jobId:$jobId, jobName:$jobName, canonicalId:$canonicalId, createdVia:$createdVia, text:$text, time:$time, originalTime:$originalTime, user:$user, channel:$channel}'
