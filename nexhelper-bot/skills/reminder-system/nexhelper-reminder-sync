#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")" 2>/dev/null || dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../common/nexhelper-core.sh"

nx_init_dirs

synced=0
skipped=0
errors=0

# Try CLI list with a timeout to detect WebSocket issues early.
cron_jobs="$(timeout 8 openclaw cron list --json 2>/dev/null || echo "")"
CLI_WORKS=true
if [ -z "$cron_jobs" ] || ! echo "$cron_jobs" | jq -e '.jobs' >/dev/null 2>&1; then
  CLI_WORKS=false
  cron_jobs='{"jobs":[]}'
fi

cron_messages="$(echo "$cron_jobs" | jq -r '[.jobs[].payload.message // empty] | join("\n")')"
cron_names="$(echo "$cron_jobs" | jq -r '[.jobs[].name // empty] | join("\n")')"

# Also check jobs.json directly for file-based fallback entries
JOBS_FILE="$HOME/.openclaw/cron/jobs.json"
file_messages=""
file_names=""
if [ -f "$JOBS_FILE" ]; then
  file_messages="$(jq -r '[.jobs[]?.payload.message // empty] | join("\n")' "$JOBS_FILE" 2>/dev/null || echo "")"
  file_names="$(jq -r '[.jobs[]?.name // empty] | join("\n")' "$JOBS_FILE" 2>/dev/null || echo "")"
fi

now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

for f in $(nx_list_reminder_files); do
  rem="$(cat "$f")"
  status="$(echo "$rem" | jq -r '.status')"
  [ "$status" = "scheduled" ] || continue

  text="$(echo "$rem" | jq -r '.text')"
  datetime="$(echo "$rem" | jq -r '.datetime')"
  user_id="$(echo "$rem" | jq -r '.userId')"
  channel="$(echo "$rem" | jq -r '.channel // "last"')"
  rem_id="$(echo "$rem" | jq -r '.id')"

  # Resolve "last" → concrete channel (isolated cron has no channel context)
  if [ "$channel" = "last" ]; then
    if [[ "$user_id" == +* ]]; then
      channel="whatsapp"
    elif [[ "$user_id" =~ ^[0-9]+$ ]]; then
      channel="telegram"
    fi
  fi

  if ! nx_is_iso_timestamp "$datetime"; then
    errors=$((errors + 1))
    continue
  fi

  if [ "$datetime" \< "$now" ]; then
    skipped=$((skipped + 1))
    continue
  fi

  # Dedup against both CLI-listed jobs and direct file entries
  marker="ERINNERUNG: $text"
  if echo "$cron_messages" | grep -qF "$marker" 2>/dev/null; then
    skipped=$((skipped + 1)); continue
  fi
  if echo "$file_messages" | grep -qF "$marker" 2>/dev/null; then
    skipped=$((skipped + 1)); continue
  fi
  if echo "$cron_names" | grep -qF "$rem_id" 2>/dev/null; then
    skipped=$((skipped + 1)); continue
  fi
  if echo "$file_names" | grep -qF "$rem_id" 2>/dev/null; then
    skipped=$((skipped + 1)); continue
  fi

  # If CLI doesn't work, don't try to add via CLI — the set-reminder
  # fallback already wrote to jobs.json. Just skip.
  if [ "$CLI_WORKS" = false ]; then
    skipped=$((skipped + 1))
    continue
  fi

  cron_result="$(timeout 10 openclaw cron add \
    --name "sync-$rem_id" \
    --at "$datetime" \
    --session isolated \
    --message "⏰ ERINNERUNG: $text" \
    --announce \
    --channel "$channel" \
    --to "$user_id" \
    --delete-after-run \
    --json 2>/dev/null || echo "{}")"

  cron_id="$(echo "$cron_result" | jq -r '.id // empty' 2>/dev/null || echo "")"
  if [ -n "$cron_id" ]; then
    synced=$((synced + 1))
  else
    errors=$((errors + 1))
  fi
done

jq -c -n \
  --argjson synced "$synced" \
  --argjson skipped "$skipped" \
  --argjson errors "$errors" \
  --argjson cliAvailable "$( [ "$CLI_WORKS" = true ] && echo true || echo false)" \
  '{status:"ok", synced:$synced, skipped:$skipped, errors:$errors, cliAvailable:$cliAvailable}'
