#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")" 2>/dev/null || dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../common/nexhelper-core.sh"

# Convert relative time string (e.g., "2m", "1h", "30s", "1d") to absolute ISO timestamp
# Returns the original value if already an ISO timestamp
parse_relative_time() {
  local input="$1"
  
  # Check if already an ISO timestamp (contains T or is a date)
  if [[ "$input" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2} ]] || [[ "$input" =~ T ]]; then
    echo "$input"
    return 0
  fi
  
  # Parse relative time: <number><unit> (e.g., "2m", "1h", "30s", "1d")
  local num="${input%[smhd]}"
  local unit="${input: -1}"
  
  if [[ ! "$num" =~ ^[0-9]+$ ]]; then
    # Can't parse - return as-is (will likely fail later)
    echo "$input"
    return 1
  fi
  
  local seconds
  case "$unit" in
    s) seconds="$num" ;;
    m) seconds=$((num * 60)) ;;
    h) seconds=$((num * 3600)) ;;
    d) seconds=$((num * 86400)) ;;
    *) 
      # Unknown unit - return as-is
      echo "$input"
      return 1
      ;;
  esac
  
  # Calculate absolute timestamp
  date -u -d "@$(($(date +%s) + seconds))" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || \
    date -u -v+${seconds}S +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || \
    echo "$input"
}

create_reminder() {
  local user_id="$1"
  local text="$2"
  local datetime="$3"
  local channel="$4"
  local idempotency_key="$5"
  nx_init_dirs
  if [ -n "$idempotency_key" ] && nx_idempotency_has "$idempotency_key"; then
    nx_idempotency_get "$idempotency_key"
    return
  fi
  local reminder_id
  reminder_id="$(nx_op_id rem)"
  local op_id
  op_id="$(nx_op_id remop)"
  
  # Convert relative time to absolute ISO timestamp
  local absolute_datetime
  absolute_datetime="$(parse_relative_time "$datetime")"
  
  local payload
  payload="$(jq -c -n \
    --arg id "$reminder_id" \
    --arg userId "$user_id" \
    --arg text "$text" \
    --arg datetime "$absolute_datetime" \
    --arg originalDatetime "$datetime" \
    --arg channel "$channel" \
    --arg now "$(nx_now_iso)" \
    '{
      id:$id,
      userId:$userId,
      text:$text,
      datetime:$datetime,
      originalDatetime:$originalDatetime,
      channel:$channel,
      status:"scheduled",
      delivered:false,
      cancelled:false,
      retries:0,
      createdAt:$now,
      updatedAt:$now,
      deliveredAt:null
    }')"
  nx_write_reminder_json "$reminder_id" "$payload"
  local result
  result="$(jq -c -n --arg status "created" --arg opId "$op_id" --argjson reminder "$payload" \
    '{status:$status,opId:$opId,reminder:$reminder}')"
  if [ -n "$idempotency_key" ]; then
    nx_idempotency_put "$idempotency_key" "$result"
  fi
  nx_log_event "reminder.create" "$op_id" "success" "$result"
  echo "$result"
}

list_reminders() {
  local user_id="$1"
  nx_init_dirs
  local arr="[]"
  local f
  for f in $(nx_list_reminder_files); do
    local r
    r="$(cat "$f")"
    if [ "$(echo "$r" | jq -r --arg u "$user_id" '.userId == $u')" = "true" ]; then
      arr="$(echo "$arr" | jq -c --argjson r "$r" '. + [$r]')"
    fi
  done
  echo "$arr" | jq -c 'sort_by(.datetime)'
}

delete_reminder() {
  local reminder_id="$1"
  local actor="${2:-}"
  nx_init_dirs
  local rem
  rem="$(nx_load_reminder_json "$reminder_id")"
  if [ "$(echo "$rem" | jq -r '.id // empty')" = "" ]; then
    jq -c -n --arg status "not_found" --arg id "$reminder_id" '{status:$status,id:$id}'
    return
  fi
  local owner
  owner="$(echo "$rem" | jq -r '.userId')"
  if [ -n "$actor" ] && [ "$actor" != "$owner" ] && ! nx_is_admin "$actor"; then
    jq -c -n --arg status "forbidden" --arg id "$reminder_id" \
      '{status:$status,id:$id,message:"Nur der Ersteller oder ein Admin kann diese Erinnerung löschen."}'
    return 1
  fi
  local updated
  updated="$(echo "$rem" | jq -c --arg now "$(nx_now_iso)" '.cancelled=true | .status="cancelled" | .updatedAt=$now')"
  nx_write_reminder_json "$reminder_id" "$updated"
  jq -c -n --arg status "deleted" --arg id "$reminder_id" '{status:$status,id:$id}'
}

mark_due() {
  nx_init_dirs
  local now
  now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  local due="[]"
  local f
  for f in $(nx_list_reminder_files); do
    local r
    r="$(cat "$f")"
    local status
    status="$(echo "$r" | jq -r '.status')"
    if [ "$status" != "scheduled" ]; then
      continue
    fi
    local dt
    dt="$(echo "$r" | jq -r '.datetime')"
    # Skip if datetime doesn't look like a valid ISO timestamp
    if [[ ! "$dt" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T ]]; then
      continue
    fi
    if [ "$dt" \< "$now" ] || [ "$dt" = "$now" ]; then
      local updated
      updated="$(echo "$r" | jq -c --arg now "$(nx_now_iso)" '.status="delivered" | .delivered=true | .deliveredAt=$now | .updatedAt=$now')"
      local id
      id="$(echo "$r" | jq -r '.id')"
      nx_write_reminder_json "$id" "$updated"
      due="$(echo "$due" | jq -c --argjson u "$updated" '. + [$u]')"
    fi
  done
  echo "$due"
}

usage() {
  echo "NexHelper Reminder CLI"
  echo "  create --user <id> --text <text> --datetime <iso|relative> [--channel telegram] [--idempotency-key <key>]"
  echo "    Relative time examples: 2m (minutes), 1h (hours), 30s (seconds), 1d (days)"
  echo "  list --user <id>"
  echo "  delete <reminder_id> [--actor <user_id>]"
  echo "  due"
}

CMD="${1:-}"
shift || true
case "$CMD" in
  create)
    USER_ID=""
    TEXT=""
    DATETIME=""
    CHANNEL="telegram"
    IDEMPOTENCY_KEY=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --user) USER_ID="$2"; shift 2 ;;
        --text) TEXT="$2"; shift 2 ;;
        --datetime) DATETIME="$2"; shift 2 ;;
        --channel) CHANNEL="$2"; shift 2 ;;
        --idempotency-key) IDEMPOTENCY_KEY="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    create_reminder "$USER_ID" "$TEXT" "$DATETIME" "$CHANNEL" "$IDEMPOTENCY_KEY"
    ;;
  list)
    if [ "${1:-}" = "--user" ]; then
      list_reminders "${2:-}"
    else
      usage
      exit 1
    fi
    ;;
  delete)
    REM_ID="${1:-}"
    shift || true
    ACTOR=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --actor) ACTOR="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    delete_reminder "$REM_ID" "$ACTOR"
    ;;
  due)
    mark_due
    ;;
  *)
    usage
    exit 1
    ;;
esac
