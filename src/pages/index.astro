        ease: 'power2.out',
        onStart: function() {
            document.querySelector('.chat-anim-3').style.transform = 'translateY(10px)';
        }
    });
    
    gsap.to('.chat-anim-4', {
        opacity: 1,
        y: 0,
        duration: 0.5,
        delay: 2.7,
        ease: 'power2.out',
        onStart: function() {
            document.querySelector('.chat-anim-4').style.transform = 'translateY(10px)';
        }
    });
}
</script>
