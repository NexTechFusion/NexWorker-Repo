        <script is:inline>
            function updateCalc() {
                const monteure = document.getElementById('input-monteure').value;
                const zeit = 15;
                const stundensatz = 60;
                
                document.getElementById('val-monteure').textContent = monteure;
                
                const gesamtMinutenMonat = monteure * zeit * 20;
                const stundenMonat = Math.round(gesamtMinutenMonat / 60);
                const euroJahr = Math.round(stundenMonat * stundensatz * 12);
                
                document.getElementById('res-stunden').textContent = stundenMonat;
                document.getElementById('res-euro').textContent = euroJahr.toLocaleString('de-DE');
            }

            document.getElementById('input-monteure')?.addEventListener('input', updateCalc);
            updateCalc();
