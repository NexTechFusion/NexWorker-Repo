---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WhatsApp Dokumentation ohne App" isMainPage={true}>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-surface" id="hero">
        <div class="absolute inset-0 bg-grid-dark pointer-events-none z-0 opacity-60"></div>
        <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[70%] rounded-full bg-brand/[0.07] blur-[100px] pointer-events-none"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[40%] h-[50%] rounded-full bg-brand/[0.05] blur-[80px] pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 relative z-10 pt-28 pb-16 md:pt-36 md:pb-24 lg:pt-40 lg:pb-28">
            <div class="flex flex-col lg:grid lg:grid-cols-2 lg:gap-20 items-center">

                <div class="text-center lg:text-left order-2 lg:order-1 mt-12 lg:mt-0 gs-reveal-hero">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/[0.06] backdrop-blur border border-white/10 text-slate-300 text-xs font-medium mb-8">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
                        </span>
                        Fuer Bauleiter, Monteure, Reinigungsfirmen und Field Service
                    </div>

                    <h1 class="text-[2.75rem] leading-[1.05] sm:text-5xl md:text-[3.75rem] lg:text-[4.25rem] font-bold tracking-tight text-white mb-5">
                        Schluss mit Zettelwirtschaft.<br />
                        <span class="text-brand-light">Dokumentation ohne App.</span>
                    </h1>

                    <p class="text-base sm:text-lg md:text-xl text-slate-400 max-w-xl mx-auto lg:mx-0 leading-relaxed mb-10 font-light">
                        Ihre Monteure chatten &ndash; NexWorker macht die Dokumentation. Zeiten, Fotos und Wissen automatisch erfasst. Keine App, 15 Min. Setup, DSGVO-konform.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
                        <a href="#cta" class="group bg-brand hover:bg-brand-dark text-white px-7 py-3.5 rounded-xl font-semibold text-[15px] transition-all shadow-glow hover:shadow-lg inline-flex items-center justify-center gap-2">
                            Demo-Nummer anfordern
                            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </a>
                        <a href="#tagesablauf" class="bg-white/[0.06] hover:bg-white/[0.1] border border-white/10 text-slate-200 px-7 py-3.5 rounded-xl font-semibold text-[15px] transition-all inline-flex items-center justify-center gap-2">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Workflow ansehen
                        </a>
                    </div>

                    <div class="mt-10 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-[13px] text-slate-500 font-medium">
                        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Dokumentation ohne App</span>
                        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Beweissicherung</span>
                        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> ERP-Integration</span>
                    </div>
                </div>

                <!-- Phone Mockup -->
                <div class="order-1 lg:order-2 relative gs-reveal-hero w-full max-w-[280px] sm:max-w-[300px] lg:max-w-[320px] mx-auto" id="hero-phone-container">
                    <div class="relative bg-slate-800 rounded-[2.5rem] p-[6px] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.5)] ring-1 ring-white/[0.08]">
                        <div class="w-full aspect-[9/18.5] bg-white rounded-[2.2rem] overflow-hidden flex flex-col relative">
                            <div class="absolute top-0 inset-x-0 h-6 flex justify-center z-30 pt-1.5">
                                <div class="w-20 h-[18px] bg-slate-800 rounded-full"></div>
                            </div>

                            <div class="bg-white/95 backdrop-blur pt-9 pb-3 px-4 flex items-center gap-2.5 z-20 border-b border-slate-100">
                                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm overflow-hidden border border-slate-100 p-1">
                                    <img src="/logo.png" alt="NexWorker Assistant" class="w-full h-full object-contain">
                                </div>
                                <div class="min-w-0">
                                    <p class="font-semibold text-slate-800 text-[13px] leading-tight truncate">NexWorker</p>
                                    <p class="text-[10px] text-emerald-500 font-medium">Online</p>
                                </div>
                            </div>

                            <div class="flex-1 bg-slate-50 px-3 py-3 flex flex-col justify-end gap-2.5 overflow-hidden">
                                <div class="self-end chat-bubble-user bg-chat-user border border-sky-100 max-w-[82%] px-3 py-2 shadow-sm chat-anim-1 opacity-0">
                                    <p class="text-[12px] leading-snug text-slate-700 font-medium">Moin, bin da. Mit Axel bei Kunde Mueller.</p>
                                    <span class="text-[9px] text-slate-400 block text-right mt-0.5">07:00</span>
                                </div>

                                <div class="self-start chat-bubble-bot bg-white border border-slate-200 max-w-[88%] px-3 py-2.5 shadow-sm relative chat-anim-2 opacity-0">
                                    <div class="absolute left-0 top-2.5 bottom-2.5 w-[3px] bg-brand rounded-r"></div>
                                    <div class="text-[11px] font-mono text-slate-600 space-y-1.5 pl-2">
                                        <div class="flex items-center gap-1.5 text-emerald-600 font-semibold">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                            Check-In 07:00
                                        </div>
                                        <div class="text-slate-500">Team: Lars, Axel</div>
                                        <div class="text-slate-500">Ort: Kunde Mueller</div>
                                        <div class="pt-1 mt-1 border-t border-slate-100 text-brand font-semibold text-[10px]">Projektbuchung aktiv</div>
                                    </div>
                                </div>

                                <div class="self-end chat-bubble-user bg-chat-user border border-sky-100 max-w-[60%] px-3 py-2 shadow-sm flex items-center gap-2 chat-anim-3 opacity-0">
                                    <div class="w-7 h-7 rounded-full bg-brand flex items-center justify-center flex-shrink-0">
                                        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    </div>
                                    <div class="flex-1">
                                        <div class="w-full bg-sky-200/80 h-1 rounded-full relative">
                                            <div class="absolute left-0 top-0 h-full bg-brand rounded-full w-[45%]"></div>
                                        </div>
                                    </div>
                                    <span class="text-[10px] text-slate-500 font-medium tabular-nums">0:14</span>
                                </div>

                                <div class="self-start chat-bubble-bot bg-white border border-slate-200 max-w-[88%] px-3 py-2.5 shadow-sm relative chat-anim-4 opacity-0">
                                    <div class="absolute left-0 top-2.5 bottom-2.5 w-[3px] bg-emerald-500 rounded-r"></div>
                                    <div class="text-[11px] font-mono pl-2">
                                        <div class="flex items-center gap-1.5 text-emerald-600 font-semibold">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                            Material erfasst
                                        </div>
                                        <div class="text-slate-500 mt-1">3x NYM-J Kabel &middot; <span class="text-brand font-semibold">147,50 EUR</span></div>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-white border-t border-slate-100 px-3 py-2 flex items-center gap-2 z-20">
                                <div class="flex-1 bg-slate-50 border border-slate-200 h-8 rounded-full px-3 flex items-center text-[11px] text-slate-400 font-medium">Nachricht...</div>
                                <div class="w-8 h-8 bg-brand rounded-full flex items-center justify-center text-white flex-shrink-0">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
    </section>

    <!-- Was ist NexWorker -->
    <section id="was-ist" class="py-16 md:py-24 bg-slate-50 relative border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16 gs-fade-up">
                <span class="text-brand font-bold uppercase tracking-widest text-xs mb-3 block">Plattform Architektur</span>
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-6 tracking-tight flex items-center justify-center gap-3">
                    <svg class="w-7 h-7 md:w-8 md:h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                    Was ist NexWorker?
                </h2>
                <p class="text-base md:text-lg text-slate-500 leading-relaxed">
                    Keine isolierte Softwareinsel. NexWorker ist eine KI-gestuetzte Wissensdatenbank und Dokumentationsplattform, die in bekannten Messengern arbeitet und Daten strukturiert an Ihr Buero uebergibt.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
                <div class="space-y-4 gs-fade-up">
                    <div class="group flex gap-4 md:gap-5 p-4 md:p-5 rounded-2xl bg-white border border-slate-100 shadow-sm hover:border-brand/30 hover:shadow-md transition-all duration-300 relative overflow-hidden">
                        <div class="absolute inset-y-0 left-0 w-1 bg-brand transform scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
                        <div class="flex-shrink-0">
                            <div class="w-11 h-11 md:w-12 md:h-12 rounded-xl bg-slate-50 flex items-center justify-center text-slate-600 group-hover:text-brand group-hover:bg-brand/5 transition-colors border border-slate-100 shadow-inner-light">
                                <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-base md:text-lg font-bold text-slate-800 mb-1.5 md:mb-2 tracking-tight">Semantische Sprachanalyse</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">Gesprochene Notizen werden transkribiert, kontextualisiert und fuer die digitale Wissenssicherung strukturiert.</p>
                        </div>
                    </div>
                    
                    <div class="group flex gap-4 md:gap-5 p-4 md:p-5 rounded-2xl bg-white border border-slate-100 shadow-sm hover:border-brand/30 hover:shadow-md transition-all duration-300 relative overflow-hidden">
                        <div class="absolute inset-y-0 left-0 w-1 bg-brand transform scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
                        <div class="flex-shrink-0">
                            <div class="w-11 h-11 md:w-12 md:h-12 rounded-xl bg-slate-50 flex items-center justify-center text-slate-600 group-hover:text-brand group-hover:bg-brand/5 transition-colors border border-slate-100 shadow-inner-light">
                                <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-base md:text-lg font-bold text-slate-800 mb-1.5 md:mb-2 tracking-tight">Visuelle Baudokumentation</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">Gesendete Fotos werden projektbezogen archiviert. So entsteht eine nachvollziehbare Baudokumentation.</p>
                        </div>
                    </div>

                    <div class="group flex gap-4 md:gap-5 p-4 md:p-5 rounded-2xl bg-white border border-slate-100 shadow-sm hover:border-brand/30 hover:shadow-md transition-all duration-300 relative overflow-hidden">
                        <div class="absolute inset-y-0 left-0 w-1 bg-brand transform scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
                        <div class="flex-shrink-0">
                            <div class="w-11 h-11 md:w-12 md:h-12 rounded-xl bg-slate-50 flex items-center justify-center text-slate-600 group-hover:text-brand group-hover:bg-brand/5 transition-colors border border-slate-100 shadow-inner-light">
                                <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-base md:text-lg font-bold text-slate-800 mb-1.5 md:mb-2 tracking-tight">Automatisierte Berichterstellung</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">Aggregiert Daten in Echtzeit zu sauberen Tagesberichten und reduziert die fehleranfaellige Nacherfassung.</p>
                        </div>
                    </div>
                </div>

                <div class="bg-surface rounded-3xl p-8 md:p-10 relative overflow-hidden shadow-2xl gs-fade-up border border-slate-700">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-brand/20 rounded-full blur-[80px] -mr-20 -mt-20 pointer-events-none"></div>
                    
                    <div class="relative z-10">
                        <svg class="w-9 h-9 md:w-10 md:h-10 text-brand mb-5 md:mb-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 md:mb-4 tracking-tight">Zero Onboarding.</h3>
                        <p class="text-slate-300 text-sm md:text-base leading-relaxed mb-6 md:mb-8 font-light">
                            Ein digitaler Mitarbeiter, der sofort produktiv ist. Keine App-Rollouts, keine vergessenen Passwoerter, keine Schulungstage.
                        </p>
                        
                        <div class="border-t border-slate-700/50 pt-5 md:pt-6">
                            <div class="flex items-center gap-4 md:gap-5 text-white">
                                <div class="w-12 h-12 md:w-14 md:h-14 bg-brand rounded-xl flex items-center justify-center font-bold text-xl md:text-2xl shadow-glow">15</div>
                                <div>
                                    <p class="font-bold text-base md:text-lg">Minuten Setup-Zeit</p>
                                    <p class="text-slate-400 text-xs md:text-sm">bis zum ersten korrekten Tagesbericht.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Target Audiences -->
    <section class="py-12 md:py-16 bg-white border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-10 md:mb-12 gs-fade-up">
                <h2 class="text-xl md:text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight mb-3 md:mb-4">Fuer alle, die draussen arbeiten und drinnen abrechnen.</h2>
                <p class="text-slate-500 text-sm md:text-base max-w-2xl mx-auto">NexWorker passt sich Ihrem Gewerk an – nicht umgekehrt.</p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 gs-fade-up">
                <div class="text-center p-4 md:p-5 rounded-2xl border border-slate-100 bg-slate-50 hover:border-brand/30 hover:shadow-md transition-all">
                    <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-2 md:mb-3 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
                        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    </div>
                    <h3 class="font-bold text-slate-900 text-xs md:text-sm mb-1">Bauleiter</h3>
                    <p class="text-[10px] md:text-xs text-slate-500 leading-relaxed hidden sm:block">Baufortschritt, Maengel und Abnahmen</p>
                </div>
                <div class="text-center p-4 md:p-5 rounded-2xl border border-slate-100 bg-slate-50 hover:border-brand/30 hover:shadow-md transition-all">
                    <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-2 md:mb-3 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
                        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <h3 class="font-bold text-slate-900 text-xs md:text-sm mb-1">Monteure</h3>
                    <p class="text-[10px] md:text-xs text-slate-500 leading-relaxed hidden sm:block">Zeiten, Material und Wissen per Chat</p>
                </div>
                <div class="text-center p-4 md:p-5 rounded-2xl border border-slate-100 bg-slate-50 hover:border-brand/30 hover:shadow-md transition-all">
                    <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-2 md:mb-3 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
                        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                    </div>
                    <h3 class="font-bold text-slate-900 text-xs md:text-sm mb-1">Reinigungsfirmen</h3>
                    <p class="text-[10px] md:text-xs text-slate-500 leading-relaxed hidden sm:block">Objekte und Leistungen nachweisen</p>
                </div>
                <div class="text-center p-4 md:p-5 rounded-2xl border border-slate-100 bg-slate-50 hover:border-brand/30 hover:shadow-md transition-all">
                    <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-2 md:mb-3 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
                        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <h3 class="font-bold text-slate-900 text-xs md:text-sm mb-1">Field Service</h3>
