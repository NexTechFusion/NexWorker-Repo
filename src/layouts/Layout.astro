---
interface Props {
	title: string;
	description?: string;
  isMainPage?: boolean;
}

const { title, description = "Messenger-basierte Dokumentation fuer Handwerk. Keine App, 15 Min. Setup, DSGVO-konform.", isMainPage = false } = Astro.props;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} | NexWorker</title>
		<meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    
    <!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Tailwind & GSAP Scripts -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        brand: {
                            DEFAULT: '#4F46E5', // Indigo 600
                            dark: '#3730A3',    // Indigo 800
                            light: '#818CF8',   // Indigo 400
                            50: '#EEF2FF'       // Indigo 50
                        },
                        surface: {
                            DEFAULT: '#0F172A', // Slate 900
                            light: '#1E293B',   // Slate 800
                            dark: '#020617'     // Slate 950
                        },
                        chat: {
                            bg: '#F8FAFC',      // Slate 50
                            user: '#E0F2FE',    // Light Sky Blue
                            bot: '#FFFFFF'
                        }
                    },
                    boxShadow: {
                        'soft': '0 4px 20px -2px rgba(15, 23, 42, 0.05)',
                        'floating': '0 20px 40px -10px rgba(15, 23, 42, 0.1)',
                        'inner-light': 'inset 0 2px 4px 0 rgba(255, 255, 255, 0.1)',
                        'glow': '0 0 20px rgba(79, 70, 229, 0.3)',
                    }
                }
            }
        }
    </script>

    <style is:global>
        body {
            background-color: #F8FAFC;
            color: #334155;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .bg-grid {
            background-size: 40px 40px;
            background-image: linear-gradient(to right, rgba(15, 23, 42, 0.03) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(15, 23, 42, 0.03) 1px, transparent 1px);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
            -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
        }

        .bg-grid-dark {
            background-size: 40px 40px;
            background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        }

        .chat-bubble-user {
            position: relative;
            border-radius: 1rem;
            border-bottom-right-radius: 0.25rem;
        }
        
        .chat-bubble-bot {
            position: relative;
            border-radius: 1rem;
            border-bottom-left-radius: 0.25rem;
        }

        @keyframes hero-float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        .gs-float {
            animation: hero-float 4s ease-in-out infinite;
        }

        .perspective-1000 {
            perspective: 1000px;
        }

        /* Nav Transition Styles */
        .nav-solid {
            background-color: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(8px) !important;
            box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1) !important;
            border-bottom: 1px solid #e2e8f0 !important;
        }
    </style>
	</head>
	<body class="selection:bg-brand selection:text-white relative">
		<!-- Navigation -->
    <nav class="fixed w-full z-50 transition-all duration-500" id="navbar">
        <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16 md:h-20">
                <a href="/" class="flex items-center gap-2.5">
                    <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-inner-light overflow-hidden border border-slate-100">
                        <img src="/logo.png" alt="NexWorker Logo" class="w-full h-full object-cover">
                    </div>
                    <span class="font-bold text-lg tracking-tight nav-logo-text text-white transition-colors duration-500">NexWorker</span>
                </a>

                <div class="hidden md:flex items-center gap-8">
                    <a href={isMainPage ? "#was-ist" : "/#was-ist"} class="nav-link text-slate-300 hover:text-white transition-colors font-medium text-sm">Plattform</a>
                    <a href={isMainPage ? "#kill-shots" : "/#kill-shots"} class="nav-link text-slate-300 hover:text-white transition-colors font-medium text-sm">Vorteile</a>
                    <a href={isMainPage ? "#tagesablauf" : "/#tagesablauf"} class="nav-link text-slate-300 hover:text-white transition-colors font-medium text-sm">Workflow</a>
                    <a href={isMainPage ? "#faq" : "/#faq"} class="nav-link text-slate-300 hover:text-white transition-colors font-medium text-sm">FAQ</a>
                    <a href="#cta" class="bg-brand hover:bg-brand-dark text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all shadow-md hover:shadow-lg">Demo starten</a>
                </div>
            </div>
        </div>
    </nav>

		<slot />

		<footer class="bg-surface py-10 text-center relative overflow-hidden">
        <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-[300px] h-[100px] bg-brand/20 blur-[50px] pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-4 relative z-10 flex flex-col items-center">
            <div class="flex items-center justify-center gap-3 mb-6">
                <div class="w-8 h-8 bg-slate-800 rounded-lg flex items-center justify-center border border-slate-700">
                    <svg class="w-4 h-4 text-brand-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <span class="text-slate-200 font-semibold tracking-wide">NexWorker</span>
            </div>
            
            <div class="flex gap-6 mb-8 mt-2">
                <a href="/datenschutz" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Datenschutz</a>
                <a href="/impressum" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">Impressum</a>
            </div>

            <p class="text-slate-600 text-xs font-mono">© {new Date().getFullYear()} NexTech Fusion GmbH. All rights reserved.</p>
        </div>
    </footer>

    <script is:inline>
        window.addEventListener('load', () => {
            const nav = document.getElementById('navbar');
            const navLogoText = nav.querySelector('.nav-logo-text');
            const navLinks = nav.querySelectorAll('.nav-link');

            function updateNav() {
                const scrolled = window.scrollY > 50;

                if (scrolled) {
                    nav.classList.add('nav-solid');
                    navLogoText.classList.add('text-surface');
                    navLogoText.classList.remove('text-white');
                    navLinks.forEach(l => {
                        l.classList.add('text-slate-500', 'hover:text-surface');
                        l.classList.remove('text-slate-300', 'hover:text-white');
                    });
                } else {
                    nav.classList.remove('nav-solid');
                    navLogoText.classList.remove('text-surface');
                    navLogoText.classList.add('text-white');
                    navLinks.forEach(l => {
                        l.classList.remove('text-slate-500', 'hover:text-surface');
                        l.classList.add('text-slate-300', 'hover:text-white');
                    });
                }
            }

            window.addEventListener('scroll', updateNav, { passive: true });
            updateNav();

            if (typeof gsap !== 'undefined') {
                gsap.registerPlugin(ScrollTrigger);
                
                gsap.from('.gs-reveal-hero', {
                    y: 30,
                    opacity: 0,
                    duration: 1,
                    stagger: 0.2,
                    ease: "power3.out"
                });

                document.querySelectorAll('.gs-fade-up').forEach(elem => {
                    gsap.from(elem, {
                        scrollTrigger: { trigger: elem, start: "top 88%" },
                        y: 24,
                        opacity: 0,
                        duration: 0.7,
                        ease: "power2.out"
                    });
                });

                document.querySelectorAll('.timeline-item').forEach((item, i) => {
                    gsap.from(item, {
                        scrollTrigger: { trigger: item, start: "top 82%" },
                        y: 24,
                        opacity: 0,
                        duration: 0.5,
                        delay: i * 0.08,
                        ease: "power2.out"
                    });
                });
            }
        });
    </script>
	</body>
</html>
